def prompt_text(label: str, default: str) -> str:
    raw_value = input(f"{label} [{default}]: ").strip()
    return raw_value or default


def prompt_choice(label: str, options: list[tuple[str, str]], default: str) -> str:
    option_index = {str(index): value for index, (value, _) in enumerate(options, start=1)}
    values = {value for value, _ in options}
    default_index = next(
        str(index)
        for index, (value, _) in enumerate(options, start=1)
        if value == default
    )
    print(label)
    for index, (value, description) in enumerate(options, start=1):
        default_note = " [default]" if value == default else ""
        print(f"  {index}. {value}{default_note}")
        print(f"     {description}")
    while True:
        raw_value = input(f"Choose an option [{default_index}]: ").strip().lower()
        if not raw_value:
            return default
        if raw_value in option_index:
            return option_index[raw_value]
        if raw_value in values:
            return raw_value
        print("Enter the option number or value shown above.")


def prompt_yes_no(label: str, default: bool = True) -> bool:
    suffix = "Y/n" if default else "y/N"
    while True:
        raw_value = input(f"{label} [{suffix}]: ").strip().lower()
        if not raw_value:
            return default
        if raw_value in {"y", "yes"}:
            return True
        if raw_value in {"n", "no"}:
            return False
        print("Enter yes or no.")


def prompt_optional_text(label: str, default: str = "") -> str:
    suffix = f" [{default}]" if default else ""
    raw_value = input(f"{label}{suffix}: ").strip()
    return raw_value or default


def prompt_targets(default_targets: list[str]) -> list[str]:
    current_default = "both" if set(default_targets) == VALID_TARGETS else default_targets[0]
    choice = prompt_choice(
        "Which targets should the first pass support?",
        [
            ("both", "Render both Cursor and Claude outputs from the same spec."),
            ("cursor", TARGET_DESCRIPTIONS["cursor"]),
            ("claude", TARGET_DESCRIPTIONS["claude"]),
        ],
        current_default,
    )
    if choice == "both":
        return sorted(VALID_TARGETS)
    return [choice]


