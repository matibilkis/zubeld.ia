def detect_package_manager(target_dir: Path) -> str:
    if (target_dir / "pnpm-lock.yaml").exists() or (target_dir / "pnpm-workspace.yaml").exists():
        return "pnpm"
    if (target_dir / "yarn.lock").exists():
        return "yarn"
    if (target_dir / "bun.lockb").exists() or (target_dir / "bun.lock").exists():
        return "bun"
    return "npm"


def package_script_command(package_manager: str, script_name: str) -> str:
    if package_manager == "npm":
        return "npm test" if script_name == "test" else f"npm run {script_name}"
    return f"{package_manager} {script_name}"


def looks_like_placeholder_package_script(command: str) -> bool:
    normalized = normalize_compare_text(command)
    return "no test specified" in normalized or normalized.startswith("echo ") and "exit 1" in normalized


def docs_command_score(command: str) -> int:
    normalized = normalize_compare_text(command)
    if any(keyword in normalized for keyword in ("vale", "markdownlint", "remark", "lychee", "linkinator", "linkchecker")):
        return 100
    if "mkdocs" in normalized or "sphinx-build" in normalized or "mdbook test" in normalized:
        return 90
    return 0


def code_command_score(command: str) -> int:
    normalized = normalize_compare_text(command)
    score = 0
    if normalized.startswith(("make ", "npm ", "pnpm ", "yarn ", "bun ", "tox", "nox", "poetry run ", "uv run ")):
        score += 10
    if any(
        marker in normalized
        for marker in (
            "pytest",
            "python -m pytest",
            "go test",
            "cargo test",
            " manage.py test",
            "npm test",
            "pnpm test",
            "yarn test",
            "bun test",
            "vitest",
            "jest",
            "make test",
            "make check",
            "make verify",
            "tox",
            "nox",
        )
    ):
        score += 100
    elif any(marker in normalized for marker in ("ruff check", "mypy", "pyright", "go vet", "cargo clippy", "eslint", "tsc", "lint")):
        score += 75
    elif any(marker in normalized for marker in ("py_compile", "cargo check", "build")):
        score += 45
    return score


def rank_commands(commands: list[str], score_fn) -> list[str]:
    scored = []
    seen = set()
    for index, command in enumerate(commands):
        normalized = normalize_compare_text(command)
        if not normalized or normalized in seen:
            continue
        seen.add(normalized)
        scored.append((-score_fn(command), index, command))
    scored.sort()
    return [command for _score, _index, command in scored]


def parse_makefile_targets(path: Path) -> set[str]:
    if not path.exists():
        return set()
    try:
        text = read_text(path)
    except UnicodeDecodeError:
        return set()
    targets = set()
    for line in text.splitlines():
        if not line or line.startswith(("\t", " ", "#", ".")):
            continue
        match = re.match(r"^([A-Za-z0-9_.-]+)\s*:", line)
        if match:
            targets.add(match.group(1))
    return targets


def extract_ci_run_commands(text: str) -> list[str]:
    commands = []
    lines = text.splitlines()
    index = 0
    while index < len(lines):
        line = lines[index]
        match = re.match(r"^(\s*)(?:-\s*)?run:\s*(.*)$", line)
        if not match:
            index += 1
            continue
        indent = len(match.group(1))
        value = match.group(2).strip()
        if value in {"|", ">"}:
            index += 1
            block_lines = []
            while index < len(lines):
                nested = lines[index]
                if not nested.strip():
                    index += 1
                    continue
                nested_indent = len(nested) - len(nested.lstrip(" "))
                if nested_indent <= indent:
                    break
                block_lines.append(nested.strip())
                index += 1
            candidate_text = "\n".join(block_lines)
        else:
            candidate_text = value
            index += 1
        for chunk in re.split(r"\s*(?:&&|;|\|\|)\s*", candidate_text):
            cleaned = chunk.strip()
            if cleaned:
                commands.append(cleaned)
    return commands


def ci_candidate_files(target_dir: Path) -> list[Path]:
    candidates = []
    for relative_path, _label in CI_MARKERS:
        candidate = target_dir / relative_path
        if candidate.is_file():
            candidates.append(candidate)
            continue
        if candidate.is_dir():
            candidates.extend(sorted(child for child in candidate.glob("*") if child.is_file()))
    return candidates


def classify_validation_command(command: str) -> str:
    normalized = normalize_compare_text(command)
    if docs_command_score(command) > 0:
        return "docs"
    if code_command_score(command) > 0:
        return "code"
    if any(marker in normalized for marker in ("test", "check", "verify", "lint")):
        return "code"
    return "other"


def collect_ci_validation_commands(target_dir: Path) -> tuple[list[str], list[str]]:
    code_commands = []
    docs_commands = []
    for path in ci_candidate_files(target_dir):
        text = read_text_limited(path, char_limit=12000)
        if not text:
            continue
        for command in extract_ci_run_commands(text):
            classification = classify_validation_command(command)
            if classification == "docs":
                docs_commands.append(command)
            elif classification == "code":
                code_commands.append(command)
    return rank_commands(code_commands, code_command_score), rank_commands(docs_commands, docs_command_score)


def collect_package_script_validation_commands(target_dir: Path) -> tuple[list[str], list[str], list[str]]:
    scripts = parse_package_scripts(target_dir / "package.json")
    if not scripts:
        return [], [], []
    package_manager = detect_package_manager(target_dir)
    code_commands = []
    docs_commands = []
    test_markers = []
    preferred_scripts = [
        "test",
        "test:ci",
        "test:unit",
        "check",
        "verify",
        "lint",
        "typecheck",
        "build",
        "docs:check",
        "docs:lint",
        "docs:test",
    ]
    remaining = sorted(name for name in scripts if name not in preferred_scripts)
    for name in preferred_scripts + remaining:
        if name not in scripts:
            continue
        raw_command = normalize_string(scripts.get(name), "")
        if not raw_command or looks_like_placeholder_package_script(raw_command):
            continue
        command = package_script_command(package_manager, name)
        if docs_command_score(raw_command) > 0 or docs_command_score(command) > 0 or name.startswith("docs:"):
            docs_commands.append(command)
            continue
        if any(token in name for token in ("test", "check", "verify", "lint", "type")):
            code_commands.append(command)
            if "test" in name:
                test_markers.append(command)
    return (
        rank_commands(code_commands, code_command_score),
        rank_commands(docs_commands, docs_command_score),
        dedupe_nonempty(test_markers),
    )


def pyproject_mentions(path: Path, markers: list[str]) -> bool:
    if not path.exists():
        return False
    text = read_text_limited(path, char_limit=12000).lower()
    return any(marker in text for marker in markers)


def collect_python_validation_commands(target_dir: Path) -> list[str]:
    commands = []
    pyproject = target_dir / "pyproject.toml"
    if (target_dir / "tox.ini").exists():
        commands.append("tox")
    if (target_dir / "noxfile.py").exists():
        commands.append("nox")
    if (target_dir / "pytest.ini").exists() or pyproject_mentions(pyproject, ["[tool.pytest", "pytest"]):
        commands.append("pytest")
    if any((target_dir / name).exists() for name in ("ruff.toml", ".ruff.toml")) or pyproject_mentions(pyproject, ["[tool.ruff"]):
        commands.append("ruff check .")
    if any((target_dir / name).exists() for name in ("mypy.ini", ".mypy.ini")) or pyproject_mentions(pyproject, ["[tool.mypy"]):
        commands.append("mypy .")
    if (target_dir / "pyrightconfig.json").exists() or (target_dir / "pyrightconfig.jsonc").exists():
        commands.append("pyright")
    if (target_dir / "manage.py").exists():
        manage_text = read_text_limited(target_dir / "manage.py", char_limit=2000).lower()
        if "django" in manage_text:
            commands.append("python3 manage.py test")
    python_check = detect_python_entrypoint(target_dir)
    if python_check:
        commands.append(python_check)
    return rank_commands(commands, code_command_score)


def choose_orchestration_files(target_dir: Path, limit: int = 10) -> list[Path]:
    selected = []
    seen = set()

    def add_path(path: Path) -> None:
        if len(selected) >= limit:
            return
        if not path.exists() or not path.is_file() or not is_text_file(path):
            return
        key = str(path)
        if key in seen:
            return
        seen.add(key)
        selected.append(path)

    for relative_path in ORCHESTRATION_PRIORITY_FILES:
        add_path(target_dir / relative_path)
    for relative_dir, pattern in ORCHESTRATION_PRIORITY_DIRS:
        directory = target_dir / relative_dir
        if not directory.exists() or not directory.is_dir():
            continue
        for child in sorted(directory.glob(pattern)):
            add_path(child)
            if len(selected) >= limit:
                break
    return selected[:limit]


def choose_repo_heuristic_files(target_dir: Path, limit: int = 8) -> list[Path]:
    selected = []
    seen = set()

    def add_path(path: Path) -> None:
        if len(selected) >= limit:
            return
        if not path.exists() or not path.is_file() or not is_text_file(path):
            return
        if is_orchestration_artifact_path(path, target_dir):
            return
        key = str(path)
        if key in seen:
            return
        seen.add(key)
        selected.append(path)

    for name in SUGGEST_MANIFEST_FILES:
        add_path(target_dir / name)
    for relative_path, _label in CI_MARKERS:
        candidate = target_dir / relative_path
        if candidate.is_file():
            add_path(candidate)
        elif candidate.is_dir():
            for child in sorted(candidate.glob("*")):
                add_path(child)
                if len(selected) >= limit:
                    break
    for path in sorted(target_dir.glob("README*")):
        add_path(path)
    for path in sorted(target_dir.glob("*.md")):
        add_path(path)
    repo_entrypoint = target_dir / target_dir.name
    add_path(repo_entrypoint)
    for relative_path in SUGGEST_SOURCE_CANDIDATES:
        add_path(target_dir / relative_path)
    for path in sorted(target_dir.glob("*.py")):
        add_path(path)
    return selected[:limit]


def collect_file_snippets(target_dir: Path, selected_files: list[Path]) -> list[dict]:
    file_snippets = []
    for path in selected_files:
        text = read_text_limited(path)
        if not text:
            continue
        file_snippets.append(
            {
                "path": str(path.relative_to(target_dir)),
                "content": text,
            }
        )
    return file_snippets


def collect_suggest_evidence(target_dir: Path, blueprint_path: Path) -> dict:
    blueprint_text = read_text(blueprint_path)
    raw_spec = require_dict(parse_blueprint_block(blueprint_text, SPEC_MARKERS, "spec"), "spec")
    spec = normalize_spec(raw_spec)
    metadata = load_generated_metadata(blueprint_text)
    repo_hints = collect_repo_hints(target_dir)
    orchestration_files = collect_file_snippets(target_dir, choose_orchestration_files(target_dir))
    repo_files = collect_file_snippets(target_dir, choose_repo_heuristic_files(target_dir))
    evidence = {
        "rawSpec": raw_spec,
        "spec": spec,
        "metadata": metadata,
        "repoHints": repo_hints,
        "topLevelEntries": list_top_level_entries(target_dir),
        "orchestrationFiles": orchestration_files,
        "repoFiles": repo_files,
        "evidenceTiers": {
            "orchestration": {
                "weight": 3,
                "files": [item["path"] for item in orchestration_files],
            },
            "repo": {
                "weight": 1,
                "files": [item["path"] for item in repo_files],
            },
        },
    }
    evidence["repoBrief"] = build_repo_brief(target_dir, evidence)
    return evidence


def has_python_shebang(path: Path) -> bool:
    if not path.exists() or not path.is_file():
        return False
    text = read_text_limited(path, char_limit=200)
    first_line = text.splitlines()[0] if text.splitlines() else ""
    return first_line.startswith("#!") and "python" in first_line.lower()


def looks_like_python_entrypoint(path: Path) -> bool:
    if not path.exists() or not path.is_file():
        return False
    name = path.name
    if name.startswith("."):
        return False
    if has_python_shebang(path):
        return True
    return name in {"main.py", "app.py", "manage.py"} or str(path).endswith("/src/main.py")


def python_entrypoint_candidates(target_dir: Path) -> list[Path]:
    candidates = [target_dir / target_dir.name]
    candidates.extend(target_dir / relative_path for relative_path in SUGGEST_SOURCE_CANDIDATES)
    candidates.extend(
        sorted(
            path
            for path in target_dir.iterdir()
            if path.is_file() and path.suffix == "" and not path.name.startswith(".") and path.stat().st_mode & 0o111
        )
    )
    candidates.extend(sorted(target_dir.glob("*.py")))

    unique = []
    seen = set()
    for path in candidates:
        key = str(path)
        if key in seen:
            continue
        seen.add(key)
        unique.append(path)
    return unique


def infer_primary_ecosystem(target_dir: Path) -> tuple[str, str]:
    if (
        (target_dir / "pyproject.toml").exists()
        or (target_dir / "setup.py").exists()
        or any(target_dir.glob("*.py"))
        or any(has_python_shebang(path) for path in python_entrypoint_candidates(target_dir))
    ):
        return ("python", "Python repo markers detected.")
    if (target_dir / "package.json").exists():
        return ("javascript", "JavaScript or TypeScript repo markers detected.")
    if (target_dir / "Cargo.toml").exists():
        return ("rust", "Rust repo markers detected.")
    if (target_dir / "go.mod").exists():
        return ("go", "Go repo markers detected.")
    return ("generic", "No strong language-specific manifest detected.")


def detect_python_entrypoint(target_dir: Path) -> str:
    for path in python_entrypoint_candidates(target_dir):
        if looks_like_python_entrypoint(path):
            return f"python3 -m py_compile ./{path.relative_to(target_dir)}"
    return ""


def detect_orchestration_artifacts(orchestration_files: list[dict]) -> list[str]:
    artifacts = []
    file_paths = [item["path"] for item in orchestration_files]
    roots = {
        "init-orch.md": lambda path: path == "init-orch.md",
        "AGENTS.md": lambda path: path == "AGENTS.md",
        ".cursor/": lambda path: path.startswith(".cursor/"),
        ".claude/": lambda path: path.startswith(".claude/"),
        "orch/": lambda path: path.startswith("orch/"),
    }
    for label, matcher in roots.items():
        if any(matcher(path) for path in file_paths):
            artifacts.append(label)
    return artifacts


def dedupe_nonempty(items: list[str]) -> list[str]:
    unique = []
    for item in items:
        if item and item not in unique:
            unique.append(item)
    return unique


def build_repo_brief(target_dir: Path, evidence: dict) -> dict:
    spec = evidence["spec"]
    repo_hints = evidence["repoHints"]
    orchestration_files = evidence["orchestrationFiles"]
    repo_files = evidence["repoFiles"]
    readme_paragraph = ""
    for item in repo_files:
        if item["path"].lower().startswith("readme"):
            readme_paragraph = first_meaningful_paragraph(item["content"])
            if readme_paragraph:
                break

    ecosystem, ecosystem_reason = infer_primary_ecosystem(target_dir)
    repo_text_blob = "\n".join(item["content"] for item in repo_files).lower()
    code_checks = list(repo_hints.get("suggestedChecks", []))
    if not code_checks and repo_hints["suggestedCheck"]:
        code_checks.append(repo_hints["suggestedCheck"])
    if not code_checks and ecosystem == "python" and (target_dir / "tests").is_dir() and "pytest" in repo_text_blob:
        code_checks.append("pytest")

    docs_checks = []
    if (
        spec["domainPreset"] == "docs"
        or any(
            path.lower().startswith("docs/") or path.lower().startswith("readme") or path.lower().endswith(".md")
            for path in [item["path"] for item in repo_files]
        )
    ):
        docs_checks.extend(repo_hints.get("docsChecks", []))
        if not docs_checks:
            docs_checks.append("Review changed docs for broken links, formatting, and clarity.")

    orchestration_artifacts = detect_orchestration_artifacts(orchestration_files)
    existing_targets = dedupe_nonempty(list(spec["targets"]) + list(evidence["metadata"]["renderedTargets"]))
    targets_text = ", ".join(existing_targets) if existing_targets else "tool-specific"
    summary = spec["project"]["summary"]
    mission = spec["project"]["mission"]
    meaningful_summary = not looks_like_generic_orchestration_text(summary)
    meaningful_mission = not looks_like_generic_orchestration_text(mission)
    agents_mission = ""
    for item in orchestration_files:
        if item["path"] != "AGENTS.md":
            continue
        agents_mission = first_descriptive_line(extract_markdown_section(item["content"], "Mission"))
        if agents_mission:
            break

    repo_identity = ""
    repo_identity_confidence = "low"
    identity_notes = []
    if meaningful_summary:
        repo_identity = summary
        repo_identity_confidence = "high"
        identity_notes.append("Current init-orch summary already carries repo-specific intent.")
    elif readme_paragraph and any(keyword in normalize_compare_text(readme_paragraph) for keyword in ("orchestration", "agent", "workflow", "cursor", "claude")):
        repo_identity = readme_paragraph
        repo_identity_confidence = "medium"
        identity_notes.append("README reinforces an orchestration-focused repository identity.")
    elif len(orchestration_artifacts) >= 2:
        repo_identity = (
            f"Repository with an existing orchestration contract spanning {', '.join(orchestration_artifacts)} "
            f"and generated setup for {targets_text}."
        )
        repo_identity_confidence = "medium"
        identity_notes.append("Existing orchestration artifacts outweigh shallow repo-shape heuristics.")
    elif readme_paragraph:
        repo_identity = readme_paragraph
        repo_identity_confidence = "high"
        identity_notes.append("README provided the clearest repository description.")
    else:
        repo_identity = f"{target_dir.name}: practical, reviewable progress with agent help."
        identity_notes.append("No strong repo description found, so the brief fell back to a generic summary.")

    workflow_identity = ""
    workflow_identity_confidence = "low"
    if meaningful_mission:
        workflow_identity = mission
        workflow_identity_confidence = "high"
    elif agents_mission and not looks_like_generic_orchestration_text(agents_mission):
        workflow_identity = agents_mission
        workflow_identity_confidence = "medium"
    elif len(orchestration_artifacts) >= 2:
        workflow_identity = (
            f"Keep the orchestration contract reviewable and aligned across {targets_text} outputs while staying safe on existing repositories."
        )
        workflow_identity_confidence = "medium"
    elif spec["workflowPreset"] == "research":
        workflow_identity = "Help humans explore, synthesize, and refine ideas without over-committing to premature implementation."
        workflow_identity_confidence = "medium"
    else:
        workflow_identity = "Keep human and agent work aligned around practical, reviewable improvements."

    repo_shape = "generic software repo"
    if len(orchestration_artifacts) >= 2:
        repo_shape = "orchestration-aware tooling repo"
    elif ecosystem == "python" and readme_paragraph:
        repo_shape = "python tooling or CLI repo"
    elif spec["domainPreset"] == "docs":
        repo_shape = "documentation-oriented repo"
    elif spec["domainPreset"] == "infra":
        repo_shape = "infrastructure-oriented repo"
    elif spec["domainPreset"] == "web-app":
        repo_shape = "web app repo"

    return {
        "repoName": target_dir.name,
        "readmeParagraph": readme_paragraph,
        "ecosystem": ecosystem,
        "ecosystemReason": ecosystem_reason,
        "repoShape": repo_shape,
        "repoIdentity": repo_identity,
        "repoIdentityConfidence": repo_identity_confidence,
        "workflowIdentity": workflow_identity,
        "workflowIdentityConfidence": workflow_identity_confidence,
        "identityNotes": identity_notes,
        "orchestrationArtifacts": orchestration_artifacts,
        "codeChecks": dedupe_nonempty(code_checks),
        "docsChecks": dedupe_nonempty(docs_checks),
        "suggestedDomain": repo_hints["suggestedDomain"],
        "workspaceMarkers": repo_hints["workspaceMarkers"],
        "ciMarkers": repo_hints["ciMarkers"],
        "topLevelEntries": evidence["topLevelEntries"],
        "orchestrationFiles": [item["path"] for item in orchestration_files],
        "repoFiles": [item["path"] for item in repo_files],
        "evidenceTiers": evidence["evidenceTiers"],
    }


def build_suggest_evidence_summary(repo_brief: dict, spec: dict) -> dict:
    evidence = {
        "identity": [],
        "workflow": [],
        "verification": [],
        "safety": [],
    }
    if repo_brief["repoIdentityConfidence"] != "low":
        evidence["identity"].append(
            f"Repo identity came from `{repo_brief['repoIdentity']}` with {repo_brief['repoIdentityConfidence']} confidence."
        )
    elif repo_brief["readmeParagraph"]:
        evidence["identity"].append("README provided some repo identity context, but it stayed weak or generic.")
    else:
        evidence["identity"].append("No strong repo identity signal was found beyond the current spec and sampled files.")
    if repo_brief["orchestrationArtifacts"]:
        evidence["identity"].append(
            "Existing orchestration artifacts: " + ", ".join(repo_brief["orchestrationArtifacts"])
        )

    if repo_brief["workflowIdentityConfidence"] != "low":
        evidence["workflow"].append(
            f"Workflow identity came from `{repo_brief['workflowIdentity']}` with {repo_brief['workflowIdentityConfidence']} confidence."
        )
    else:
        evidence["workflow"].append(
            f"Workflow identity fell back to the `{spec['workflowPreset']}` workflow preset and current orchestration shape."
        )
    if repo_brief["workspaceMarkers"]:
        evidence["workflow"].append("Workspace markers detected: " + ", ".join(repo_brief["workspaceMarkers"]))

    if repo_brief["codeChecks"]:
        evidence["verification"].append("Code checks: " + ", ".join(repo_brief["codeChecks"]))
    else:
        evidence["verification"].append("No strong code check was detected from scripts, CI, or language-specific config.")
    if repo_brief["docsChecks"]:
        evidence["verification"].append("Docs checks: " + ", ".join(repo_brief["docsChecks"]))
    if repo_brief["ciMarkers"]:
        evidence["verification"].append("CI markers: " + ", ".join(repo_brief["ciMarkers"]))

    evidence["safety"].append(f"Risk posture in spec: `{spec['project']['riskPosture']}`.")
    if spec["toolPolicy"]["requiresApproval"]:
        evidence["safety"].append(
            "Approval-gated tools: " + ", ".join(spec["toolPolicy"]["requiresApproval"])
        )
    else:
        evidence["safety"].append("No explicit approval-gated tools are currently configured.")
    return evidence


def make_suggestion_entry(
    target: str,
    value: object,
    confidence: str,
    rationale: str,
    evidence_categories: list[str],
    evidence_items: list[str],
) -> dict:
    return {
        "target": target,
        "value": value,
        "confidence": confidence,
        "rationale": rationale,
        "evidenceCategories": evidence_categories,
        "evidence": evidence_items,
    }


def suggest_summary(repo_brief: dict, spec: dict) -> tuple[str, str]:
    if repo_brief["repoIdentity"]:
        return repo_brief["repoIdentity"], repo_brief["repoIdentityConfidence"]
    if repo_brief["readmeParagraph"]:
        return repo_brief["readmeParagraph"], "high"
    ecosystem = repo_brief["ecosystem"]
    if ecosystem == "python":
        return (
            "Python-based tooling project. Optimize for safe workflow changes, clear generated output, and focused verification.",
            "medium",
        )
    if ecosystem == "javascript":
        return (
            "JavaScript or TypeScript project. Optimize for maintainable changes, clear verification, and reviewable agent behavior.",
            "medium",
        )
    if spec["domainPreset"] == "docs":
        return (
            "Documentation-focused project. Optimize for clarity, consistency, and low-risk iteration.",
            "medium",
        )
    return (
        f"{repo_brief['repoName']}: practical, reviewable progress with agent help.",
        "low",
    )


def suggest_mission(repo_brief: dict, spec: dict) -> tuple[str, str]:
    if repo_brief["workflowIdentity"]:
        return repo_brief["workflowIdentity"], repo_brief["workflowIdentityConfidence"]
    ecosystem = repo_brief["ecosystem"]
    if ecosystem == "python":
        return (
            "Let humans and agents improve the repository through small, reviewable changes with clear verification and explicit safety boundaries.",
            "medium",
        )
    if spec["workflowPreset"] == "research":
        return (
            "Help humans explore, synthesize, and refine ideas without over-committing to premature implementation.",
            "medium",
        )
    return (
        "Keep human and agent work aligned around practical, reviewable improvements.",
        "low",
    )


def suggest_success_criteria(repo_brief: dict, spec: dict) -> tuple[list[str], str]:
    items = [
        "Ship changes that are easy to review and verify.",
        "Keep orchestration guidance easy for humans to update.",
    ]
    if repo_brief["orchestrationArtifacts"]:
        items.append("Keep the orchestration blueprint and generated artifacts aligned.")
    if repo_brief["codeChecks"]:
        items.append("Name the canonical repo checks explicitly in the orchestration.")
    if repo_brief["workspaceMarkers"]:
        items.append("Make path scoping explicit so agents know which parts of the repo to touch.")
    if spec["workflowPreset"] == "research":
        items.append("Keep findings, assumptions, and evidence easy to trace.")
    else:
        items.append("Reduce setup friction without compromising safety on existing repos.")
    deduped = []
    for item in items:
        if item not in deduped:
            deduped.append(item)
    return deduped, "medium"


def build_verification_suggestions(repo_brief: dict, spec: dict) -> tuple[list[dict], str]:
    suggested = []
    confidence = "low"
    if repo_brief["codeChecks"]:
        preferred_change_type = preferred_change_types_for_refine(spec)[0]
        primary_check = repo_brief["codeChecks"][0]
        suggested.append(
            {
                "changeType": preferred_change_type,
                "required": [
                    f"Run `{primary_check}` or explain the closest equivalent manual validation."
                ],
            }
        )
        confidence = "high" if code_command_score(primary_check) >= 75 else "medium"
    if repo_brief["docsChecks"] and not any(
        item["changeType"] == "docs" for item in spec["verification"]
    ):
        suggested.append(
            {
                "changeType": "docs",
                "required": [repo_brief["docsChecks"][0]],
            }
        )
        confidence = "high" if confidence != "low" else "medium"
    return suggested, confidence


def generate_suggestions(repo_brief: dict, raw_spec: dict, spec: dict) -> dict:
    summary, summary_confidence = suggest_summary(repo_brief, spec)
    mission, mission_confidence = suggest_mission(repo_brief, spec)
    success_criteria, criteria_confidence = suggest_success_criteria(repo_brief, spec)
    verification, verification_confidence = build_verification_suggestions(repo_brief, spec)
    evidence_summary = build_suggest_evidence_summary(repo_brief, spec)

    project_updates = {}
    project_explanations = {}
    if summary and summary != spec["project"]["summary"]:
        if summary_confidence != "low":
            project_updates["summary"] = summary
            project_explanations["summary"] = make_suggestion_entry(
                "project.summary",
                summary,
                summary_confidence,
                "Prefer repo-specific identity signals over generic preset text when the evidence is strong enough.",
                ["identity"],
                evidence_summary["identity"],
            )
    if mission and mission != spec["project"]["mission"]:
        if mission_confidence != "low":
            project_updates["mission"] = mission
            project_explanations["mission"] = make_suggestion_entry(
                "project.mission",
                mission,
                mission_confidence,
                "Prefer workflow-specific evidence over generic mission text when the repo already signals how humans and agents should work here.",
                ["workflow", "safety"],
                evidence_summary["workflow"] + evidence_summary["safety"],
            )
    if success_criteria and success_criteria != spec["project"]["successCriteria"]:
        project_updates["successCriteria"] = success_criteria
        project_explanations["successCriteria"] = make_suggestion_entry(
            "project.successCriteria",
            success_criteria,
            criteria_confidence,
            "Success criteria should reflect the repo's verification shape, orchestration footprint, and working style without overfitting to weak signals.",
            ["workflow", "verification", "safety"],
            evidence_summary["workflow"] + evidence_summary["verification"] + evidence_summary["safety"],
        )

    verification_updates = []
    verification_explanations = []
    existing_pairs = {
        (item["changeType"], tuple(item["required"]))
        for item in spec["verification"]
    }
    for item in verification:
        key = (item["changeType"], tuple(item["required"]))
        if key not in existing_pairs:
            verification_updates.append(item)
            primary_requirement = item["required"][0] if item["required"] else "Add repo-specific verification."
            rationale = (
                "Prefer a real repo-native code check over generic verification wording."
                if item["changeType"] != "docs"
                else "Keep docs checks separate from code checks so the spec stays honest about what is actually being validated."
            )
            verification_explanations.append(
                make_suggestion_entry(
                    f"verification[{item['changeType']}]",
                    item,
                    verification_confidence,
                    rationale,
                    ["verification"],
                    evidence_summary["verification"] + [f"Suggested requirement: {primary_requirement}"],
                )
            )

    questions = []
    if summary_confidence == "low":
        questions.append("Should the project summary emphasize the runtime, the workflow model, or the target ecosystems most strongly?")
    if mission_confidence == "low":
        questions.append("Should the workflow optimize more for implementation delivery, research/synthesis, or keeping Cursor and Claude aligned?")
    if verification_confidence == "low":
        questions.append("What is the canonical check this repo should run after code changes?")

    preset_suggestion = None
    preset_explanation = None
    if spec["domainPreset"] == "generic" and repo_brief["suggestedDomain"] is not None:
        suggested_domain, reason = repo_brief["suggestedDomain"]
        preset_suggestion = {
            "workflowPreset": spec["workflowPreset"],
            "domainPreset": suggested_domain,
            "reason": reason,
        }
        preset_explanation = make_suggestion_entry(
            "preset.domainPreset",
            preset_suggestion,
            "medium",
            "Only suggest a preset shift when repo-shape markers consistently point away from the generic domain.",
            ["identity", "verification"],
            evidence_summary["identity"] + evidence_summary["verification"] + [reason],
        )

    return {
        "project": project_updates,
        "verification": verification_updates,
        "presetSuggestion": preset_suggestion,
        "explanations": {
            "project": project_explanations,
            "verification": verification_explanations,
            "presetSuggestion": preset_explanation,
            "evidenceSummary": evidence_summary,
        },
        "confidence": {
            "summary": summary_confidence,
            "mission": mission_confidence,
            "successCriteria": criteria_confidence,
            "verification": verification_confidence,
        },
        "questions": questions,
    }


def format_suggestion_report(repo_brief: dict, suggestions: dict, spec: dict) -> str:
    explanations = suggestions.get("explanations", {})
    evidence_summary = explanations.get("evidenceSummary", {})

    def append_explanation_block(entry: dict | None) -> list[str]:
        if not entry:
            return []
        lines = [
            f"  - confidence: {entry['confidence']}",
            f"  - why: {entry['rationale']}",
        ]
        if entry["evidenceCategories"]:
            lines.append("  - evidence categories: " + ", ".join(entry["evidenceCategories"]))
        for item in entry["evidence"]:
            lines.append(f"    - {item}")
        return lines

    lines = [
        "Zubeldia suggest",
        "",
        "Detected:",
        f"- orchestration artifacts: {', '.join(repo_brief['orchestrationArtifacts']) if repo_brief['orchestrationArtifacts'] else 'none detected'}",
        f"- repo shape: {repo_brief['repoShape']}",
        f"- repo identity: {repo_brief['repoIdentity']} ({repo_brief['repoIdentityConfidence']})",
        f"- workflow identity: {repo_brief['workflowIdentity']} ({repo_brief['workflowIdentityConfidence']})",
        f"- ecosystem: {repo_brief['ecosystem']} ({repo_brief['ecosystemReason']})",
        f"- code checks: {', '.join(repo_brief['codeChecks']) if repo_brief['codeChecks'] else 'none detected'}",
        f"- docs checks: {', '.join(repo_brief['docsChecks']) if repo_brief['docsChecks'] else 'none detected'}",
        f"- orchestration files sampled: {', '.join(repo_brief['orchestrationFiles']) if repo_brief['orchestrationFiles'] else 'none'}",
        f"- repo files sampled: {', '.join(repo_brief['repoFiles']) if repo_brief['repoFiles'] else 'none'}",
    ]
    if repo_brief["identityNotes"]:
        lines.append(f"- identity notes: {' '.join(repo_brief['identityNotes'])}")
    if evidence_summary:
        lines.extend(["", "Evidence summary:"])
        for category in ("identity", "workflow", "verification", "safety"):
            items = evidence_summary.get(category, [])
            label = category
            if not items:
                lines.append(f"- {label}: none")
                continue
            lines.append(f"- {label}:")
            lines.extend(f"  - {item}" for item in items)

    if suggestions["project"] or suggestions["verification"] or suggestions["presetSuggestion"]:
        lines.extend(["", "Suggested updates:"])
        if "summary" in suggestions["project"]:
            lines.append(f"- project.summary -> {suggestions['project']['summary']}")
            lines.extend(append_explanation_block(explanations.get("project", {}).get("summary")))
        if "mission" in suggestions["project"]:
            lines.append(f"- project.mission -> {suggestions['project']['mission']}")
            lines.extend(append_explanation_block(explanations.get("project", {}).get("mission")))
        if "successCriteria" in suggestions["project"]:
            lines.append("- project.successCriteria")
            lines.extend(f"  - {item}" for item in suggestions["project"]["successCriteria"])
            lines.extend(append_explanation_block(explanations.get("project", {}).get("successCriteria")))
        verification_explanations = explanations.get("verification", [])
        for index, item in enumerate(suggestions["verification"]):
            lines.append(f"- verification[{item['changeType']}]")
            lines.extend(f"  - {entry}" for entry in item["required"])
            explanation = verification_explanations[index] if index < len(verification_explanations) else None
            lines.extend(append_explanation_block(explanation))
        if suggestions["presetSuggestion"] is not None:
            lines.append(
                f"- preset suggestion -> keep `{suggestions['presetSuggestion']['workflowPreset']}` and consider `{suggestions['presetSuggestion']['domainPreset']}`"
            )
            lines.extend(append_explanation_block(explanations.get("presetSuggestion")))
    else:
        lines.extend(["", "Suggested updates:", "No conservative high-confidence changes to propose right now."])

    lines.extend(
        [
            "",
            "Confidence:",
            f"- summary: {suggestions['confidence']['summary']}",
            f"- mission: {suggestions['confidence']['mission']}",
            f"- success criteria: {suggestions['confidence']['successCriteria']}",
            f"- verification: {suggestions['confidence']['verification']}",
        ]
    )

    if suggestions["questions"]:
        lines.extend(["", "Open questions:"])
        for index, question in enumerate(suggestions["questions"], start=1):
            lines.append(f"{index}. {question}")

    lines.extend(
        [
            "",
            "Next step:",
            "Apply these suggestions only if they improve the current spec, then re-run init-orch --all and init-orch --review.",
        ]
    )
    return "\n".join(lines)


def apply_suggestions_to_spec(raw_spec: dict, suggestions: dict) -> dict:
    updated = deepcopy(raw_spec)
    project = updated.setdefault("project", {})
    if not isinstance(project, dict):
        updated["project"] = {}
        project = updated["project"]
    for key, value in suggestions["project"].items():
        project[key] = value

    verification = updated.setdefault("verification", [])
    if not isinstance(verification, list):
        updated["verification"] = []
        verification = updated["verification"]
    existing_pairs = {
        (entry.get("changeType"), tuple(entry.get("required", [])))
        for entry in verification
        if isinstance(entry, dict)
    }
    for item in suggestions["verification"]:
        key = (item["changeType"], tuple(item["required"]))
        if key not in existing_pairs:
            verification.append(item)
            existing_pairs.add(key)
    return updated


def run_suggest_step(target_dir: Path, blueprint_path: Path) -> bool:
    evidence = collect_suggest_evidence(target_dir, blueprint_path)
    suggestions = generate_suggestions(evidence["repoBrief"], evidence["rawSpec"], evidence["spec"])
    report = format_suggestion_report(evidence["repoBrief"], suggestions, evidence["spec"])
    print(report)

    if not (suggestions["project"] or suggestions["verification"]):
        return False

    if not sys.stdin.isatty() or not sys.stdout.isatty():
        print("")
        print("Non-interactive session detected, so suggestions were printed only.")
        return False

    if not prompt_yes_no("Apply these suggestions to init-orch.md now?", default=False):
        print("Suggest finished. No files were written.")
        return False

    updated_spec = apply_suggestions_to_spec(evidence["rawSpec"], suggestions)
    blueprint_text = read_text(blueprint_path)
    updated_blueprint = replace_block(blueprint_text, SPEC_MARKERS, updated_spec)
    write_text(blueprint_path, updated_blueprint)
    print(f"Updated {blueprint_path}.")
    print(next_step_message("init-orch --all", "to recompile generated files."))
    return True


def run_guided_bootstrap(
    target_dir: Path,
    preset: str = DEFAULT_PRESET,
) -> tuple[Path | None, bool, str, list[str]]:
    repo_name = target_dir.name or "new-repo"
    _, default_workflow, default_domain = normalize_composed_preset(preset)
    print("Zubeldia bootstrap")
    print("Estimated setup time: about 2 minutes.")
    print("This creates a practical first draft for the repo. You can refine init-orch.md later.")
    print("If you are unsure, start with engineering-generic for most software repos.")
    print("")

    workflow = prompt_choice(
        "Pick the workflow that best matches the working style",
        [(value, WORKFLOW_PRESET_DESCRIPTIONS[value]) for value in VALID_WORKFLOW_PRESETS],
        default_workflow,
    )
    print("")
    domain = prompt_choice(
        "Pick the domain that best matches the repo shape",
        [(value, DOMAIN_PRESET_DESCRIPTIONS[value]) for value in VALID_DOMAIN_PRESETS],
        default_domain,
    )
    print("")
    summary = prompt_text(
        "Short project summary",
        f"{repo_name}: practical, reviewable progress with agent help.",
    )
    print("")
    targets = prompt_targets(sorted(VALID_TARGETS))
    print("")
    risk_posture = prompt_choice(
        "Choose the default risk posture",
        [(value, RISK_POSTURE_DESCRIPTIONS[value]) for value in ("low", "moderate", "high", "strict")],
        "moderate",
    )
    print("")

    chosen_preset = compose_preset(workflow, domain)
    print("About to create the first draft:")
    print(f"- preset: {chosen_preset}")
    print(f"- targets: {', '.join(targets)}")
    print(f"- risk posture: {risk_posture}")
    print(f"- summary: {summary}")
    print("- editable source of truth: init-orch.md")
    if not prompt_yes_no("Write the bootstrap file now?", default=True):
        print("Bootstrap cancelled. No files were written.")
        return None, False, chosen_preset, targets

    spec = build_guided_bootstrap_spec(repo_name, chosen_preset, summary, targets, risk_posture)
    blueprint_path = target_dir / "init-orch.md"
    write_text(blueprint_path, default_blueprint(repo_name, chosen_preset, spec=spec))
    return blueprint_path, True, chosen_preset, targets


def first_render_command(targets: list[str]) -> str:
    effective_targets = sorted({target for target in targets if target in VALID_TARGETS})
    if len(effective_targets) == 1:
        return f"init-orch --{effective_targets[0]}"
    return "init-orch --all"


def next_step_message(command: str, reason: str = "") -> str:
    if reason:
        return f"Next: run {command} {reason}"
    return f"Next: run {command}"


def recommendation_fingerprint(item: dict) -> str:
    payload = json.dumps(
        {
            "category": normalize_string(item.get("category"), ""),
            "title": normalize_string(item.get("title"), ""),
            "recommendation": normalize_string(item.get("recommendation"), ""),
            "rationale": normalize_string(item.get("rationale"), ""),
        },
        sort_keys=True,
        separators=(",", ":"),
    )
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()[:12]


def recommendation_priority(item: dict) -> int:
    explicit = item.get("priority")
    if isinstance(explicit, int):
        return explicit
    category = normalize_string(item.get("category"), "")
    priorities = {
        "render": 100,
        "security": 95,
        "quality": 85,
        "workflow": 80,
        "project": 70,
        "iteration": 60,
        "imports": 50,
        "repo-shape": 45,
        "repo-hygiene": 40,
    }
    return priorities.get(category, 30)


def rank_recommendation_items(items: list[dict]) -> list[dict]:
    return sorted(
        items,
        key=lambda item: (
            -recommendation_priority(item),
            normalize_string(item.get("title"), ""),
        ),
    )


def refinement_field_specs(existing_notes: dict, repo_hints: dict) -> list[dict]:
    return [
        {
            "key": "commonWork",
            "label": "What kinds of changes are most common here",
            "default": normalize_string(existing_notes.get("commonWork"), ""),
        },
        {
            "key": "primaryVerification",
            "label": "What verification command or manual check matters most",
            "default": normalize_string(existing_notes.get("primaryVerification"), "") or repo_hints["suggestedCheck"],
        },
        {
            "key": "sensitivePaths",
            "label": "Any directories or file patterns that need extra care",
            "default": normalize_string(existing_notes.get("sensitivePaths"), ""),
        },
        {
            "key": "existingConventions",
            "label": "Any existing policies or conventions to respect",
            "default": normalize_string(existing_notes.get("existingConventions"), ""),
        },
    ]


def choose_refinement_fields(field_specs: list[dict], update_existing: bool) -> list[dict]:
    if update_existing:
        return field_specs
    return [field for field in field_specs if not field["default"]]


def run_refine_step(target_dir: Path, blueprint_path: Path) -> bool:
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        raise ValueError("--refine requires an interactive terminal.")

    blueprint_text = read_text(blueprint_path)
    raw_spec = require_dict(parse_blueprint_block(blueprint_text, SPEC_MARKERS, "spec"), "spec")
    spec = normalize_spec(raw_spec)
    repo_hints = collect_repo_hints(target_dir)

    existing_notes = raw_spec.get("refinementNotes", {})
    if not isinstance(existing_notes, dict):
        existing_notes = {}

    print("Zubeldia refine")
    print("Estimated setup time: about 2 minutes.")
    print("This step tailors the generated structure to the actual repo without making bootstrap heavier.")
    print("")

    field_specs = refinement_field_specs(existing_notes, repo_hints)
    known_fields = [field for field in field_specs if field["default"]]
    update_existing = False
    if known_fields:
        print("Saved refinement notes:")
        for field in known_fields:
            print(f"- {field['key']}: {field['default']}")
        update_existing = prompt_yes_no("Update the saved refine answers?", default=False)
        print("")

    values = {field["key"]: field["default"] for field in field_specs}
    for field in choose_refinement_fields(field_specs, update_existing):
        values[field["key"]] = prompt_optional_text(field["label"], field["default"])

    common_work = values["commonWork"]
    primary_verification = values["primaryVerification"]
    sensitive_paths = values["sensitivePaths"]
    conventions = values["existingConventions"]

    print("")
    print("About to refine init-orch.md with:")
    print(f"- common work: {common_work or 'no change'}")
    print(f"- primary verification: {primary_verification or 'no change'}")
    print(f"- sensitive paths: {sensitive_paths or 'no change'}")
    print(f"- existing conventions: {conventions or 'no change'}")
    if not prompt_yes_no("Update init-orch.md now?", default=True):
        print("Refine cancelled. No files were written.")
        return False

    rules = raw_spec.setdefault("rules", [])
    if not isinstance(rules, list):
        raw_spec["rules"] = []
        rules = raw_spec["rules"]

    if common_work:
        upsert_list_entry(rules, f"Optimize the workflow for common repo work such as: {common_work}.")
    if sensitive_paths:
        upsert_list_entry(rules, f"Use extra care in these paths or file patterns: {sensitive_paths}.")
    if conventions:
        upsert_list_entry(rules, f"Respect these existing repo conventions: {conventions}.")
    if primary_verification:
        requirement = f"Run `{primary_verification}` or explain the closest equivalent manual validation."
        add_verification_requirement(raw_spec, preferred_change_types_for_refine(spec), requirement)

    raw_spec["refinementNotes"] = {
        "lastRefinedAt": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "commonWork": common_work,
        "primaryVerification": primary_verification,
        "sensitivePaths": sensitive_paths,
        "existingConventions": conventions,
    }
    existing_snapshot = {
        "commonWork": normalize_string(existing_notes.get("commonWork"), ""),
        "primaryVerification": normalize_string(existing_notes.get("primaryVerification"), ""),
        "sensitivePaths": normalize_string(existing_notes.get("sensitivePaths"), ""),
        "existingConventions": normalize_string(existing_notes.get("existingConventions"), ""),
    }
    updated_snapshot = {
        "commonWork": common_work,
        "primaryVerification": primary_verification,
        "sensitivePaths": sensitive_paths,
        "existingConventions": conventions,
    }
    if existing_snapshot == updated_snapshot:
        print("Refine captured no new repo-specific information.")
        print(next_step_message("init-orch --review", "for a lighter setup check."))
        return False

    updated_blueprint = replace_block(blueprint_text, SPEC_MARKERS, raw_spec)
    write_text(blueprint_path, updated_blueprint)
    print(f"Updated {blueprint_path}.")
    print(next_step_message("init-orch --all", "to recompile the generated files."))
    return True


def parse_blueprint_block(blueprint_text: str, markers: tuple[str, str], label: str) -> object:
    try:
        return json.loads(extract_block(blueprint_text, markers, label))
    except json.JSONDecodeError as exc:
        raise ValueError(f"Invalid JSON in the {label} block: {exc}") from exc


def collect_review_context(
    target_dir: Path,
    blueprint_path: Path,
    raw_spec: dict,
    spec: dict,
    metadata: dict,
    selected_targets: list[str],
) -> list[dict]:
    items = []
    last_rendered_raw = metadata.get("lastRenderedAt")
    rendered_targets = metadata.get("renderedTargets", [])
    rendered_spec_digest = normalize_string(metadata.get("specDigest"), "")
    current_spec_digest = spec_digest(spec)
    ownership = build_render_ownership(target_dir, spec, selected_targets)
    conflicts = collect_render_conflicts(target_dir, ownership, metadata)
    repo_hints = collect_repo_hints(target_dir)
    verification_summary = verification_text(spec)
    refinement_notes = raw_spec.get("refinementNotes", {})
    if not isinstance(refinement_notes, dict):
        refinement_notes = {}

    if conflict_report_has_items(conflicts):
        items.append(
            {
                "category": "render",
                "priority": 100,
                "title": "Confirm existing repo structure before the next render",
                "recommendation": "Review the existing managed roots and files, then re-run init-orch and confirm the overwrite prompt or use `--confirm-existing` when appropriate.",
                "rationale": format_collision_summary(conflicts),
            }
        )
    if not last_rendered_raw:
        items.append(
            {
                "category": "render",
                "priority": 95,
                "title": "Render the first target files",
                "recommendation": "Run `init-orch --all` or render the specific target you want to use first.",
                "rationale": "The spec exists, but the tool-specific files have not been compiled yet.",
            }
        )
    elif rendered_spec_digest and rendered_spec_digest != current_spec_digest:
        items.append(
            {
                "category": "render",
                "priority": 92,
                "title": "Re-render after spec edits",
                "recommendation": "Run `init-orch --all` after reviewing recent edits to init-orch.md.",
                "rationale": "The current spec no longer matches the last compiled setup.",
            }
        )
    else:
        try:
            last_rendered_at = datetime.fromisoformat(last_rendered_raw)
        except ValueError:
            last_rendered_at = None
        if last_rendered_at is not None:
            blueprint_mtime = datetime.fromtimestamp(blueprint_path.stat().st_mtime, timezone.utc)
            if blueprint_mtime.timestamp() - last_rendered_at.timestamp() > 1:
                items.append(
                    {
                        "category": "render",
                        "priority": 92,
                        "title": "Re-render after spec edits",
                        "recommendation": "Run `init-orch --all` after reviewing recent edits to init-orch.md.",
                        "rationale": "The blueprint appears newer than the latest recorded render.",
                    }
                )

    missing_targets = [target for target in spec["targets"] if target not in rendered_targets]
    if missing_targets and last_rendered_raw:
        items.append(
            {
                "category": "render",
                "priority": 88,
                "title": "Compile every configured target",
                "recommendation": "Re-run init-orch for all configured targets so the generated files stay aligned.",
                "rationale": "The spec includes "
                + ", ".join(spec["targets"])
                + " but the latest render only covered "
                + (", ".join(rendered_targets) if rendered_targets else "none")
                + ".",
            }
        )

    if last_rendered_raw and not refinement_notes.get("lastRefinedAt"):
        items.append(
            {
                "category": "workflow",
                "priority": 84,
                "title": "Run the refine step",
                "recommendation": "Run `init-orch --refine` to capture repo-specific verification, sensitive paths, and existing conventions.",
                "rationale": "The first render is complete, so this is a good time to tailor the setup to the actual repository.",
            }
        )

    default_summary = base_blueprint_spec(spec["project"]["name"])["project"]["summary"]
    if spec["project"]["summary"] == default_summary:
        items.append(
            {
                "category": "project",
                "priority": 70,
                "title": "Replace the placeholder summary",
                "recommendation": "Write a project summary that explains what good agent work should optimize for.",
                "rationale": "A specific summary makes presets, rules, and later reviews more useful.",
            }
        )

    if not spec["project"]["successCriteria"]:
        items.append(
            {
                "category": "quality",
                "priority": 72,
                "title": "Add success criteria",
                "recommendation": "List 2-4 concrete outcomes that define a good change in this repository.",
                "rationale": "Success criteria make the compile and review steps more grounded.",
            }
        )

    suggested_check = repo_hints["suggestedCheck"].lower()
    if repo_hints["suggestedCheck"] and suggested_check not in verification_summary:
        check_text = repo_hints["suggestedCheck"]
        items.append(
            {
                "category": "quality",
                "priority": 82,
                "title": "Map the canonical repo check into verification",
                "recommendation": f"Add `{check_text}` or the most relevant real repo check to the `verification` section.",
                "rationale": "The repository appears to have a concrete validation command, but the orchestration spec still describes verification in generic terms.",
            }
        )
    elif repo_hints["ciMarkers"] and not any(
        keyword in verification_summary for keyword in ("test", "pytest", "cargo test", "go test", "npm test", "make test")
    ):
        check_text = repo_hints["suggestedCheck"] or "the repo's canonical validation command"
        items.append(
            {
                "category": "quality",
                "priority": 80,
                "title": "Map real repo checks into verification",
                "recommendation": f"Add `{check_text}` or the most relevant real repo check to the `verification` section.",
                "rationale": "This repository appears to have CI or test markers, but the orchestration spec does not yet name a concrete repo-specific check.",
            }
        )

    if spec["domainPreset"] == "generic" and repo_hints["suggestedDomain"] is not None:
        suggested_domain, reason = repo_hints["suggestedDomain"]
        items.append(
            {
                "category": "repo-shape",
                "priority": 44,
                "title": "Re-check whether the generic domain is the best fit",
                "recommendation": f"Consider whether `{suggested_domain}` would be a better domain preset, or capture the repo-specific nuance explicitly in `init-orch.md`.",
                "rationale": reason,
            }
        )

    if repo_hints["workspaceMarkers"] and not any(
        keyword in " ".join(spec["rules"]).lower()
        for keyword in ("workspace", "package", "directory", "path", "subtree")
    ):
        items.append(
            {
                "category": "workflow",
                "priority": 58,
                "title": "Add path-scoping guidance for a multi-root repo",
                "recommendation": "Document which directories, packages, or subtrees agents should touch by default.",
                "rationale": "This repository has workspace-style markers, but the spec does not yet describe path scoping or subtree ownership.",
            }
        )

    planned_files = set(relative_paths(target_dir, ownership["managedFiles"]))
    stale_generated = [
        path
        for path in metadata.get("generatedFiles", [])
        if path not in planned_files and (target_dir / path).exists()
    ]
    if stale_generated:
        items.append(
            {
                "category": "repo-hygiene",
                "priority": 52,
                "title": "Review stale generated files",
                "recommendation": "Check whether previously generated files that are no longer part of the current plan should be removed or archived.",
                "rationale": "Possible stale generated files: " + summarize_paths(sorted(stale_generated)),
            }
        )

    if target_dir.name.startswith("."):
        items.append(
            {
                "category": "project",
                "priority": 30,
                "title": "Check the target directory name",
                "recommendation": "Consider setting `project.name` explicitly if the repository folder name is temporary.",
                "rationale": "Generated files reuse the directory name when no stronger project name is provided.",
            }
        )
    return rank_recommendation_items(items)


def target_specific_managed_paths(target_dir: Path, spec: dict, target: str) -> list[str]:
    ownership = build_render_ownership(target_dir, spec, [target])
    return relative_paths(target_dir, ownership["managedFiles"])


def build_parity_snapshot(target_dir: Path, spec: dict, metadata: dict) -> dict:
    shared_paths = [
        "init-orch.md",
        "AGENTS.md",
        "orch/permissions.policy.json",
        "orch/imports.lock.json",
        "orch/evaluation.plan.json",
    ]
    cursor_paths = target_specific_managed_paths(target_dir, spec, "cursor")
    claude_paths = target_specific_managed_paths(target_dir, spec, "claude")
    shared_generated = [path for path in shared_paths if path != "init-orch.md"]
    cursor_only = [path for path in cursor_paths if path not in shared_generated]
    claude_only = [path for path in claude_paths if path not in shared_generated]
    if ".gitignore" not in claude_only:
        claude_only.append(".gitignore")
    cursor_override_keys = sorted(spec["targetOverrides"]["cursor"].keys())
    claude_override_keys = sorted(spec["targetOverrides"]["claude"].keys())
    configured_targets = sorted(spec["targets"])
    rendered_targets = sorted(metadata.get("renderedTargets", []))
    missing_render_targets = [target for target in configured_targets if target not in rendered_targets]
    missing_files = {
        "cursor": [path for path in cursor_only if (target_dir / path).exists() is False],
        "claude": [path for path in claude_only if (target_dir / path).exists() is False],
        "shared": [path for path in shared_generated if (target_dir / path).exists() is False],
    }
    drift_notes = []
    if missing_render_targets:
        drift_notes.append("Not yet rendered for: " + ", ".join(missing_render_targets))
    for target in ("cursor", "claude"):
        if target in configured_targets and missing_files[target]:
            drift_notes.append(
                f"Missing expected {target} files: {summarize_paths(missing_files[target])}"
            )
    if ".gitignore" in claude_only and not (target_dir / ".gitignore").exists():
        drift_notes.append("Claude render expects a `.gitignore` entry for `.claude/settings.local.json`.")
    return {
        "configuredTargets": configured_targets,
        "renderedTargets": rendered_targets,
        "sharedSourceFields": [
            "project",
            "workflow",
            "responseStyle",
            "verification",
            "skills",
            "imports",
            "toolPolicy",
        ],
        "sharedGeneratedFiles": shared_generated,
        "cursorOnlyFiles": cursor_only,
        "claudeOnlyFiles": claude_only,
        "cursorOverrideKeys": cursor_override_keys,
        "claudeOverrideKeys": claude_override_keys,
        "driftNotes": drift_notes,
    }


def format_parity_report(target_dir: Path, spec: dict, metadata: dict, snapshot: dict) -> str:
    lines = [
        f"Zubeldia parity for {target_dir}",
        "",
        "Shared source of truth:",
        "- `init-orch.md` defines " + ", ".join(snapshot["sharedSourceFields"]) + " once for both targets.",
        "- Shared generated files: " + summarize_paths(snapshot["sharedGeneratedFiles"]),
        "",
        "Target-specific outputs:",
        "- Cursor-only files: " + summarize_paths(snapshot["cursorOnlyFiles"]) if snapshot["cursorOnlyFiles"] else "- Cursor-only files: none",
        "- Claude-only files: " + summarize_paths(snapshot["claudeOnlyFiles"]) if snapshot["claudeOnlyFiles"] else "- Claude-only files: none",
        "- Cursor anchor files: `.cursor/rules/core.mdc`, `.cursor/imports/manifest.json`, and optional `.cursor/mcp.json`.",
        "- Claude anchor files: `.claude/settings.json`, `.claude/rules/orchestration.md`, skill files, and a `.gitignore` entry for `.claude/settings.local.json`.",
        "",
        "Target-specific overrides:",
        "- Cursor overrides: " + (", ".join(snapshot["cursorOverrideKeys"]) if snapshot["cursorOverrideKeys"] else "none"),
        "- Claude overrides: " + (", ".join(snapshot["claudeOverrideKeys"]) if snapshot["claudeOverrideKeys"] else "none"),
        "",
        "Current parity status:",
        "- configured targets: " + (", ".join(snapshot["configuredTargets"]) if snapshot["configuredTargets"] else "none"),
        "- last rendered targets: " + (", ".join(snapshot["renderedTargets"]) if snapshot["renderedTargets"] else "none"),
    ]
    if snapshot["driftNotes"]:
        lines.extend(["", "Drift to inspect:"])
        lines.extend(f"- {item}" for item in snapshot["driftNotes"])
    else:
        lines.extend(["", "Drift to inspect:", "- No obvious Cursor/Claude parity drift right now."])
    lines.extend(
        [
            "",
            "Next step:",
            (
                next_step_message("init-orch --all", "to keep Cursor and Claude aligned.")
                if snapshot["driftNotes"]
                else next_step_message("init-orch --review", "after a meaningful repo or workflow change.")
            ),
        ]
    )
    return "\n".join(lines)


def format_review_report(
    target_dir: Path,
    spec: dict,
    metadata: dict,
    context_items: list[dict],
    recommendations: dict,
    parity_snapshot: dict,
    suppressed_count: int = 0,
) -> str:
    last_rendered = metadata.get("lastRenderedAt") or "never"
    rendered_targets = metadata.get("renderedTargets", [])
    immediate = context_items[:3]
    setup_items = recommendations["items"][:3]
    lines = [
        f"Zubeldia review for {target_dir}",
        "",
        "Snapshot:",
        f"- preset: {spec['preset']}",
        f"- targets in spec: {', '.join(spec['targets']) if spec['targets'] else 'none'}",
        f"- last render: {last_rendered}",
        "- last rendered targets: " + (", ".join(rendered_targets) if rendered_targets else "none"),
    ]

    if immediate:
        lines.extend(["", "Immediate actions:"])
        for index, item in enumerate(immediate, start=1):
            lines.append(f"{index}. {item['title']}")
            lines.extend(format_report_detail("Recommendation", item["recommendation"]))
            lines.extend(format_report_detail("Why", item["rationale"]))
        if len(context_items) > len(immediate):
            lines.append(f"... {len(context_items) - len(immediate)} more immediate action(s) hidden")
    else:
        lines.extend(["", "Immediate actions:", "Nothing urgent."])

    if setup_items:
        lines.extend(["", "Setup recommendations:"])
        for index, item in enumerate(setup_items, start=1):
            lines.append(f"{index}. {item['title']}")
            lines.extend(format_report_detail("Recommendation", item["recommendation"]))
            lines.extend(format_report_detail("Why", item["rationale"]))
        hidden_count = len(recommendations["items"]) - len(setup_items)
        if hidden_count > 0:
            lines.append(f"... {hidden_count} more setup recommendation(s) hidden")
        if suppressed_count:
            lines.append(f"{suppressed_count} unchanged recommendation(s) suppressed because the setup state has not changed.")
    else:
        lines.extend(["", "Setup recommendations:", "No major recommendations right now."])
        if suppressed_count:
            lines.append(f"{suppressed_count} unchanged recommendation(s) suppressed because the setup state has not changed.")

    lines.extend(["", "Parity:"])
    lines.append(
        "- shared files: "
        + summarize_paths(parity_snapshot["sharedGeneratedFiles"])
    )
    lines.append(
        "- target-specific drift: "
        + (parity_snapshot["driftNotes"][0] if parity_snapshot["driftNotes"] else "none detected")
    )

    lines.extend(
        [
            "",
            "Suggested next step:",
            (
                immediate[0]["recommendation"]
                if immediate
                else (setup_items[0]["recommendation"] if setup_items else "Keep using the current setup and re-run `init-orch --review` when the repo meaningfully changes.")
            ),
        ]
    )
    return "\n".join(lines)


def review_blueprint(target_dir: Path, blueprint_path: Path) -> str:
    blueprint_text = read_text(blueprint_path)
    raw_spec = require_dict(parse_blueprint_block(blueprint_text, SPEC_MARKERS, "spec"), "spec")
    spec = normalize_spec(raw_spec)
    metadata = load_generated_metadata(blueprint_text)
    saved_recommendations = load_saved_recommendations(blueprint_text)
    recommendations = generate_recommendations(spec)
    parity_snapshot = build_parity_snapshot(target_dir, spec, metadata)
    saved_fingerprints = {
        normalize_string(item.get("fingerprint"), "") or recommendation_fingerprint(item)
        for item in saved_recommendations["items"]
        if isinstance(item, dict)
    }
    active_recommendations = {
        **recommendations,
        "items": [
            item for item in recommendations["items"] if normalize_string(item.get("fingerprint"), "") not in saved_fingerprints
        ],
    }
    suppressed_count = len(recommendations["items"]) - len(active_recommendations["items"])
    context_items = collect_review_context(target_dir, blueprint_path, raw_spec, spec, metadata, spec["targets"])
    return format_review_report(
        target_dir,
        spec,
        metadata,
        context_items,
        active_recommendations,
        parity_snapshot,
        suppressed_count=suppressed_count,
    )


def dedupe_items(items: list[dict], key: str) -> list[dict]:
    seen = set()
    deduped = []
    for item in items:
        marker = item.get(key)
        if marker in seen:
            continue
        seen.add(marker)
        deduped.append(item)
    return deduped


def deep_merge(base: object, overrides: object) -> object:
    if isinstance(base, dict) and isinstance(overrides, dict):
        merged = {key: deepcopy(value) for key, value in base.items()}
        for key, value in overrides.items():
            if key in merged:
                merged[key] = deep_merge(merged[key], value)
            else:
                merged[key] = deepcopy(value)
        return merged
    if isinstance(base, list) and isinstance(overrides, list):
        merged = deepcopy(base)
        for item in overrides:
            if item not in merged:
                merged.append(deepcopy(item))
        return merged
    return deepcopy(overrides)


def numbered_lines(items: list[str], fallback: str) -> str:
    if not items:
        return f"1. {fallback}"
    return "\n".join(f"{index}. {item}" for index, item in enumerate(items, start=1))


def bullet_lines(items: list[str], fallback: str) -> str:
    if not items:
        return f"- {fallback}"
    return "\n".join(f"- {item}" for item in items)


def indented_block(text: str, prefix: str = "        ") -> str:
    stripped = text.strip()
    if not stripped:
        return prefix.rstrip()
    return textwrap.indent(stripped, prefix)


def response_style_overview(style: dict) -> str:
    return bullet_lines(
        [
            f"Tone: {style['tone']}",
            f"Verbosity: {style['verbosity']}",
            f"Structure: {style['structure']}",
            f"Default length: {style['defaultLength']}",
        ],
        "Add response style guidance in `init-orch.md`.",
    )


