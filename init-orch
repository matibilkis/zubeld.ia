def build_preset_spec(repo_name: str, preset: str) -> dict:
    preset_name, workflow_name, domain_name = normalize_composed_preset(preset)
    spec = base_blueprint_spec(repo_name)
    spec = deep_merge(spec, workflow_preset_overrides(workflow_name))
    spec = deep_merge(spec, domain_preset_overrides(domain_name))
    spec["preset"] = preset_name
    spec["workflowPreset"] = workflow_name
    spec["domainPreset"] = domain_name
    return spec


def default_blueprint(repo_name: str, preset: str = DEFAULT_PRESET, spec: dict | None = None) -> str:
    preset_name, workflow_name, domain_name = normalize_composed_preset(preset)
    spec = deepcopy(spec) if spec is not None else build_preset_spec(repo_name, preset_name)
    generated = {
        "version": 2,
        "lastRenderedAt": None,
        "renderedTargets": [],
        "generatedFiles": [],
        "specDigest": None,
        "resolvedImports": [],
        "bootstrapPreset": preset_name,
        "workflowPreset": workflow_name,
        "domainPreset": domain_name,
    }
    recommendations = {
        "version": 1,
        "summary": "Run `init-orch --review` for practical recommendations or render targets after editing.",
        "items": [],
    }
    priority_guidance = render_priority_guidance(workflow_name, domain_name)
    preset_provenance = render_preset_provenance_guidance(preset_name, workflow_name, domain_name)
    parts = [
        "# Init Orch",
        "",
        "`init-orch.md` is the only high-level file you should edit directly. The generated files under `.cursor/`, `.claude/`, `AGENTS.md`, and `orch/` are derived outputs.",
        "",
        f"> Security warning: {SECURITY_WARNING}",
        "",
        f"Preset: `{preset_name}`. {preset_summary(workflow_name, domain_name)}",
        "",
        *preset_provenance,
        "",
        "Edit the JSON block below freely to describe the orchestration structure you want for this repository.",
        "",
        *priority_guidance,
        "",
        "<!-- Edit the JSON spec below freely. Every field is editable. Everything else is generated from it. -->",
        "",
        json_block(SPEC_MARKERS, spec),
        "",
        "## Render Loop",
        "",
        "1. Fill in Priority 1 and 2 first. Keep the default `find-skills` import only as an optional template until the workflow feels real.",
        "2. Run `init-orch --all` for the first render, or `init-orch --cursor` / `init-orch --claude` if you only want one target.",
        "3. Run `init-orch --suggest` when you want a repo-aware proposal for summary, mission, success criteria, and verification.",
        "4. Copy or edit the default `find-skills` import when you want to add other skills, or replace it with MCP declarations when you need external tools.",
        "5. Re-run the render command after any spec change.",
        "6. Run `init-orch --refine` after the first render when you want to tailor the setup to the actual repo.",
        "7. Run `init-orch --review` whenever you want deliberate setup recommendations without rewriting files.",
        "8. Review the generated recommendations block and decide which changes belong in the spec.",
        "",
        "The generator will only rewrite the metadata and recommendations blocks below.",
        "",
        json_block(GENERATED_MARKERS, generated),
        "",
        json_block(RECOMMENDATION_MARKERS, recommendations),
    ]
    return "\n".join(parts).rstrip() + "\n"


def bootstrap_blueprint(
    target_dir: Path,
    preset: str = DEFAULT_PRESET,
    spec: dict | None = None,
) -> tuple[Path, bool]:
    blueprint_path = target_dir / "init-orch.md"
    if blueprint_path.exists():
        return blueprint_path, False
    write_text(blueprint_path, default_blueprint(target_dir.name or "new-repo", preset, spec=spec))
    return blueprint_path, True


def generate_recommendations(spec: dict) -> dict:
    items = []
    tool_policy = spec["toolPolicy"]
    if tool_policy["risky"] and not tool_policy["requiresApproval"]:
        items.append(
            {
                "category": "security",
                "priority": 95,
                "title": "Add approval gates for risky permissions",
                "recommendation": "Populate `toolPolicy.requiresApproval` for shell, delete, or broad edit access.",
                "rationale": "Risky capabilities are enabled without an explicit approval boundary.",
            }
        )

    if any(entry == "Bash(*)" for entry in tool_policy["risky"]) and spec["project"]["riskPosture"] in {"high", "strict"}:
        items.append(
            {
                "category": "security",
                "priority": 90,
                "title": "Tighten broad shell access",
                "recommendation": "Replace `Bash(*)` with narrower patterns or require approval before shell execution.",
                "rationale": "A high-risk posture and broad shell access work against each other.",
            }
        )

    if not spec["verification"]:
        items.append(
            {
                "category": "quality",
                "priority": 82,
                "title": "Add verification requirements",
                "recommendation": "Define `verification` entries by change type so agents know what checks are required.",
                "rationale": "Without change-specific verification, reviews depend too heavily on ad hoc judgment.",
            }
        )

    if not spec["workflow"]["stopConditions"]:
        items.append(
            {
                "category": "workflow",
                "priority": 78,
                "title": "Add explicit stop conditions",
                "recommendation": "Define when agents should stop and ask for help instead of pushing forward.",
                "rationale": "Stop conditions reduce unsafe improvisation and wasted effort.",
            }
        )

    for item in spec["imports"]:
        if item["trust"]["level"] == "review-required" or not item["trust"]["reviewedByHuman"]:
            items.append(
                {
                    "category": "imports",
                    "priority": 50,
                    "title": f"Review imported capability `{item['id']}`",
                    "recommendation": "Confirm trust, scope, and target mappings before relying on this import in production work.",
                    "rationale": f"Imported source `{item['source']}` is not marked as fully reviewed.",
                }
            )
        if item["version"] == "unversioned" or item["version"] == "latest":
            items.append(
                {
                    "category": "imports",
                    "priority": 46,
                    "title": f"Pin a revision for `{item['id']}`",
                    "recommendation": "Use a concrete version or revision when possible so your orchestration stays reproducible.",
                    "rationale": "Floating imports can drift and change behavior unexpectedly.",
                }
            )

    ranked_items = rank_recommendation_items(items)
    for item in ranked_items:
        item["fingerprint"] = recommendation_fingerprint(item)
    summary = "No major recommendations." if not ranked_items else f"{len(ranked_items)} recommendation(s) generated."
    return {
        "version": 1,
        "summary": summary,
        "items": ranked_items,
    }


def render_agents_file(spec: dict, recommendations: dict) -> str:
    project = spec["project"]
    response_style = spec["responseStyle"]
    targets = ", ".join(spec["targets"]) if spec["targets"] else "none"
    skills = "\n".join(
        f"- `{skill['id']}`: {skill['when']} ({skill['source']})" for skill in spec["skills"]
    ) or "- Add a skill entry in `init-orch.md` when you want reusable workflows."
    success = bullet_lines(project["successCriteria"], "Add success criteria in `init-orch.md`.")
    rules = bullet_lines(spec["rules"], "Add repository-specific rules in `init-orch.md`.")
    review = bullet_lines(
        spec["workflow"]["reviewChecklist"],
        "Add a review checklist in `init-orch.md`.",
    )
    verification = "\n".join(
        f"- `{item['changeType']}`: "
        + (", ".join(item["required"]) or "Add required checks in `init-orch.md`.")
        for item in spec["verification"]
    ) or "- Add verification requirements in `init-orch.md`."
    recommendation_titles = "\n".join(
        f"- {item['title']}" for item in recommendations["items"][:3]
    ) or "- No outstanding recommendations."

    return textwrap.dedent(
        f"""\
