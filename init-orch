def explain_preset_report(preset: str) -> str:
    preset_name, workflow, domain = normalize_composed_preset(preset)
    lines = [
        "Zubeldia preset explain",
        "",
        f"- preset: `{preset_name}`{' [default]' if preset_name == DEFAULT_PRESET else ''}",
        f"- workflow `{workflow}`: {WORKFLOW_PRESET_DESCRIPTIONS[workflow]}",
        f"- domain `{domain}`: {DOMAIN_PRESET_DESCRIPTIONS[domain]}",
        f"- combined meaning: {preset_summary(workflow, domain)}",
        "- preset role: starting draft only; every field in `init-orch.md` stays editable.",
        "- risk posture: separate from the preset so you can tune caution independently.",
        "",
        "Default emphasis:",
    ]
    lines.extend(f"- {entry}" for entry in preset_priority_emphasis(workflow, domain))
    lines.extend(["", "Good default when:"])
    if preset_name == "engineering-generic":
        lines.append("- You want the broad default for an unfamiliar software repository.")
    elif preset_name == "research-docs":
        lines.append("- You expect synthesis, evidence review, or documentation work to dominate.")
    elif preset_name == "engineering-web-app":
        lines.append("- You expect UI behavior, user flows, or browser-verified changes to matter.")
    elif preset_name == "poc-data-science":
        lines.append("- You expect quick experiments, notebooks, or model iteration to matter most.")
    else:
        lines.append(f"- You want `{workflow}` working style with `{domain}` repository bias.")
    lines.extend(
        [
            "",
            "Recommended bootstrap command:",
            f"`init-orch --preset {preset_name} --no-interactive`",
        ]
    )
    return "\n".join(lines)


