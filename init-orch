def stage_render_outputs(target_dir: Path, spec: dict, recommendations: dict, selected_targets: list[str]) -> list[Path]:
    generated_paths = render_shared_files(target_dir, spec, recommendations)
    if "cursor" in selected_targets:
        generated_paths.extend(render_cursor_files(target_dir, spec, recommendations))
    if "claude" in selected_targets:
        generated_paths.extend(render_claude_files(target_dir, spec, recommendations))
        gitignore_path = target_dir / ".gitignore"
        if gitignore_path.exists():
            generated_paths.append(gitignore_path)
    return generated_paths


def read_file_if_exists(path: Path) -> str | None:
    if not path.exists() or not path.is_file():
        return None
    return path.read_text(encoding="utf-8")


def render_preview_report(target_dir: Path, staged_dir: Path, relative_paths: list[str]) -> str:
    created = []
    updated = []
    unchanged = []
    for relative_path in sorted(set(relative_paths)):
        actual_path = target_dir / relative_path
        staged_path = staged_dir / relative_path
        actual = read_file_if_exists(actual_path)
        staged = read_file_if_exists(staged_path)
        if staged is None:
            continue
        if actual is None:
            created.append(relative_path)
        elif actual != staged:
            updated.append(relative_path)
        else:
            unchanged.append(relative_path)

    lines = [
        "Zubeldia render dry-run",
        "",
        "No files were written.",
        f"- create: {len(created)}",
        f"- update: {len(updated)}",
        f"- unchanged: {len(unchanged)}",
    ]
    if created:
        lines.extend(["", "Would create:"])
        lines.extend(f"- {path}" for path in created)
    if updated:
        lines.extend(["", "Would update:"])
        lines.extend(f"- {path}" for path in updated)
    if unchanged:
        lines.extend(["", "Already up to date:"])
        lines.extend(f"- {path}" for path in unchanged[:10])
        if len(unchanged) > 10:
            lines.append(f"- ... and {len(unchanged) - 10} more")
    lines.extend(["", "Next step:", "Re-run the same render command without `--dry-run` when the plan looks right."])
    return "\n".join(lines)


def render_targets(
    target_dir: Path,
    selected_targets: list[str],
    blueprint_path: Path,
    confirm_existing: bool = False,
    dry_run: bool = False,
) -> dict:
    blueprint_text = read_text(blueprint_path)
    try:
        raw_spec = json.loads(extract_block(blueprint_text, SPEC_MARKERS, "spec"))
    except json.JSONDecodeError as exc:
        raise ValueError(f"Invalid JSON in the spec block: {exc}") from exc

    spec = normalize_spec(raw_spec)
    metadata = load_generated_metadata(blueprint_text)
    ownership = build_render_ownership(target_dir, spec, selected_targets)
    conflicts = collect_render_conflicts(target_dir, ownership, metadata)
    if conflict_report_has_items(conflicts) and not confirm_existing:
        summary = format_collision_summary(conflicts)
        if sys.stdin.isatty() and sys.stdout.isatty():
            print(summary)
            if not prompt_yes_no("Continue with the render anyway?", default=False):
                raise ValueError("Render cancelled because generated paths overlap existing repo structure.")
        else:
            raise ValueError(summary + "\nRe-run with --confirm-existing after reviewing those paths.")

    recommendations = generate_recommendations(spec)
    if dry_run:
        with tempfile.TemporaryDirectory(prefix="init-orch-dry-run-") as temp_dir_name:
            staged_dir = Path(temp_dir_name)
            if (target_dir / ".gitignore").exists():
                write_text(staged_dir / ".gitignore", read_text(target_dir / ".gitignore"))
            generated_paths = stage_render_outputs(staged_dir, spec, recommendations, selected_targets)
            metadata = {
                "version": 2,
                "lastRenderedAt": "DRY_RUN",
                "renderedTargets": selected_targets,
                "generatedFiles": sorted(str(path.relative_to(staged_dir)) for path in generated_paths),
                "specDigest": spec_digest(spec),
                "bootstrapPreset": spec["preset"],
                "workflowPreset": spec["workflowPreset"],
                "domainPreset": spec["domainPreset"],
                "resolvedImports": [
                    {
                        "id": item["id"],
                        "type": item["type"],
                        "targets": item["targets"],
                        "version": item["version"],
                    }
                    for item in spec["imports"]
                ],
            }
            updated_blueprint = replace_block(blueprint_text, GENERATED_MARKERS, metadata)
            updated_blueprint = replace_block(updated_blueprint, RECOMMENDATION_MARKERS, recommendations)
            write_text(staged_dir / "init-orch.md", updated_blueprint)
            relative_paths = [str(path.relative_to(staged_dir)) for path in generated_paths]
            relative_paths.append("init-orch.md")
            print(render_preview_report(target_dir, staged_dir, relative_paths))
            return {"dryRun": True, "generatedPaths": relative_paths}

    generated_paths = stage_render_outputs(target_dir, spec, recommendations, selected_targets)

    metadata = {
        "version": 2,
        "lastRenderedAt": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "renderedTargets": selected_targets,
        "generatedFiles": sorted(str(path.relative_to(target_dir)) for path in generated_paths),
        "specDigest": spec_digest(spec),
        "bootstrapPreset": spec["preset"],
        "workflowPreset": spec["workflowPreset"],
        "domainPreset": spec["domainPreset"],
        "resolvedImports": [
            {
                "id": item["id"],
                "type": item["type"],
                "targets": item["targets"],
                "version": item["version"],
            }
            for item in spec["imports"]
        ],
    }
    updated_blueprint = replace_block(blueprint_text, GENERATED_MARKERS, metadata)
    updated_blueprint = replace_block(updated_blueprint, RECOMMENDATION_MARKERS, recommendations)
    write_text(blueprint_path, updated_blueprint)
    return {"dryRun": False, "generatedPaths": [str(path.relative_to(target_dir)) for path in generated_paths]}


def collect_selected_targets(args: argparse.Namespace) -> list[str]:
    selected = set()
    if args.all or args.legacy_mode == "all":
        selected.update(VALID_TARGETS)
    if args.cursor or args.legacy_mode == "cursor":
        selected.add("cursor")
    if args.claude or args.legacy_mode == "claude":
        selected.add("claude")
    return sorted(selected)


def should_run_guided_bootstrap(
    args: argparse.Namespace,
    target_dir: Path,
    selected_targets: list[str],
    preset_explicit: bool,
) -> bool:
    blueprint_path = target_dir / "init-orch.md"
    if (
        blueprint_path.exists()
        or args.no_interactive
        or args.review
        or args.parity
        or args.refine
        or args.suggest
        or args.list_presets
        or args.explain_preset
    ):
        return False
    if args.interactive:
        return True
    return (
        not preset_explicit
        and not selected_targets
        and sys.stdin.isatty()
        and sys.stdout.isatty()
    )


def main() -> int:
    args = parse_args()
    preset_explicit = "--preset" in sys.argv
    operational_flags = [
        args.init,
        args.cursor,
        args.claude,
        args.all,
        args.dry_run,
        args.review,
        args.parity,
        args.refine,
        args.suggest,
        args.interactive,
        args.no_interactive,
        args.confirm_existing,
        args.legacy_mode is not None,
    ]
    if args.list_presets:
        if args.explain_preset or any(operational_flags) or preset_explicit:
            print("Error: --list-presets must be used by itself.", file=sys.stderr)
            return 1
        print(list_presets_report())
        return 0
    if args.explain_preset:
        if any(operational_flags) or preset_explicit:
            print("Error: --explain-preset must be used by itself.", file=sys.stderr)
            return 1
        print(explain_preset_report(args.explain_preset))
        return 0
    target_dir = Path(args.dir).expanduser().resolve()
    if not target_dir.is_dir():
        print(f"Error: target directory does not exist: {target_dir}", file=sys.stderr)
        return 1

    selected_targets = collect_selected_targets(args)
    if args.dry_run and not selected_targets:
        print("Error: --dry-run only applies to render commands.", file=sys.stderr)
        return 1
    if args.confirm_existing and (args.review or args.parity or args.refine or args.suggest or not selected_targets):
        print("Error: --confirm-existing only applies to render commands.", file=sys.stderr)
        return 1
    if args.review and (args.init or selected_targets or args.parity or args.refine or args.suggest):
        print("Error: --review cannot be combined with --init, --cursor, --claude, --all, --parity, --refine, or --suggest.", file=sys.stderr)
        return 1
    if args.parity and (args.init or selected_targets or args.refine or args.suggest):
        print("Error: --parity cannot be combined with --init, --cursor, --claude, --all, --refine, or --suggest.", file=sys.stderr)
        return 1
    if args.refine and (args.init or selected_targets or args.suggest):
        print("Error: --refine cannot be combined with --init, --cursor, --claude, --all, or --suggest.", file=sys.stderr)
        return 1
    if args.suggest and (args.init or selected_targets):
        print("Error: --suggest cannot be combined with --init, --cursor, --claude, or --all.", file=sys.stderr)
        return 1

    blueprint_path = target_dir / "init-orch.md"
    if args.review:
        if not blueprint_path.exists():
            print("Error: init-orch.md does not exist yet. Run init-orch first.", file=sys.stderr)
            return 1
        try:
            print(review_blueprint(target_dir, blueprint_path))
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1
        return 0

    if args.parity:
        if not blueprint_path.exists():
            print("Error: init-orch.md does not exist yet. Run init-orch first.", file=sys.stderr)
            return 1
        try:
            blueprint_text = read_text(blueprint_path)
            raw_spec = require_dict(parse_blueprint_block(blueprint_text, SPEC_MARKERS, "spec"), "spec")
            spec = normalize_spec(raw_spec)
            metadata = load_generated_metadata(blueprint_text)
            snapshot = build_parity_snapshot(target_dir, spec, metadata)
            print(format_parity_report(target_dir, spec, metadata, snapshot))
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1
        return 0

    if args.suggest:
        if not blueprint_path.exists():
            print("Error: init-orch.md does not exist yet. Run init-orch first.", file=sys.stderr)
            return 1
        try:
            run_suggest_step(target_dir, blueprint_path)
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1
        return 0

    if args.refine:
        if not blueprint_path.exists():
            print("Error: init-orch.md does not exist yet. Run init-orch first.", file=sys.stderr)
            return 1
        try:
            run_refine_step(target_dir, blueprint_path)
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1
        return 0

    bootstrap_preset = args.preset
    guided_bootstrap_used = False
    guided_targets: list[str] = []
    if should_run_guided_bootstrap(args, target_dir, selected_targets, preset_explicit):
        blueprint_path, created, bootstrap_preset, guided_targets = run_guided_bootstrap(target_dir, args.preset)
        if not created:
            return 0
        guided_bootstrap_used = True
    else:
        blueprint_path, created = bootstrap_blueprint(target_dir, args.preset)

    if created:
        print(f"Created {blueprint_path} using preset '{bootstrap_preset}'.")
        if guided_bootstrap_used:
            print(f"Next: run {first_render_command(guided_targets or selected_targets)} to generate the first target files.")
        if selected_targets:
            print("Next: review init-orch.md if needed, then rerun the same render command.")
            return 0
    elif preset_explicit:
        print(f"Preset '{args.preset}' ignored because init-orch.md already exists.")

    if not selected_targets:
        if guided_bootstrap_used:
            return 0
        if args.init or created:
            print(f"Next: run {first_render_command(selected_targets or list(VALID_TARGETS))} when you're ready for the first render.")
            return 0
        print(f"Next: run {first_render_command(list(VALID_TARGETS))} after reviewing init-orch.md.")
        return 0

    try:
        render_result = render_targets(
            target_dir,
            selected_targets,
            blueprint_path,
            confirm_existing=args.confirm_existing,
            dry_run=args.dry_run,
        )
    except ValueError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    if render_result["dryRun"]:
        return 0
    print("Rendered orchestration files for " + ", ".join(selected_targets) + f" in {target_dir}")
    print(next_step_message("init-orch --refine", "to tailor the setup to this repo."))
    return 0


if __name__ == "__main__":
    sys.exit(main())
