            imports_path,
        ]
    )

    if spec["roles"]:
        for role in spec["roles"]:
            role_path = agents_dir / f"{sanitize_filename(role['id'], 'role')}.md"
            write_text(role_path, render_claude_role(role, spec))
            generated.append(role_path)
    else:
        gitkeep = agents_dir / ".gitkeep"
        gitkeep.touch(exist_ok=True)
        generated.append(gitkeep)

    if spec["skills"]:
        for skill in spec["skills"]:
            skill_path = skills_dir / f"{sanitize_filename(skill['id'], 'skill')}.md"
            write_text(skill_path, render_claude_skill(skill))
            generated.append(skill_path)
    else:
        gitkeep = skills_dir / ".gitkeep"
        gitkeep.touch(exist_ok=True)
        generated.append(gitkeep)

    ensure_line_in_file(target_dir / ".gitignore", ".claude/settings.local.json")
    return generated


def render_targets(target_dir: Path, selected_targets: list[str], blueprint_path: Path) -> None:
    blueprint_text = read_text(blueprint_path)
    try:
        raw_spec = json.loads(extract_block(blueprint_text, SPEC_MARKERS, "spec"))
    except json.JSONDecodeError as exc:
        raise ValueError(f"Invalid JSON in the spec block: {exc}") from exc

    spec = normalize_spec(raw_spec)
    recommendations = generate_recommendations(spec)
    generated_paths = render_shared_files(target_dir, spec, recommendations)

    if "cursor" in selected_targets:
        generated_paths.extend(render_cursor_files(target_dir, spec, recommendations))
    if "claude" in selected_targets:
        generated_paths.extend(render_claude_files(target_dir, spec, recommendations))

    metadata = {
        "version": 2,
        "lastRenderedAt": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "renderedTargets": selected_targets,
        "generatedFiles": sorted(str(path.relative_to(target_dir)) for path in generated_paths),
        "bootstrapPreset": spec["preset"],
        "workflowPreset": spec["workflowPreset"],
        "domainPreset": spec["domainPreset"],
        "resolvedImports": [
            {
                "id": item["id"],
                "type": item["type"],
                "targets": item["targets"],
                "version": item["version"],
            }
            for item in spec["imports"]
        ],
    }
    updated_blueprint = replace_block(blueprint_text, GENERATED_MARKERS, metadata)
    updated_blueprint = replace_block(updated_blueprint, RECOMMENDATION_MARKERS, recommendations)
    write_text(blueprint_path, updated_blueprint)


def collect_selected_targets(args: argparse.Namespace) -> list[str]:
    selected = set()
    if args.all or args.legacy_mode == "all":
        selected.update(VALID_TARGETS)
    if args.cursor or args.legacy_mode == "cursor":
        selected.add("cursor")
    if args.claude or args.legacy_mode == "claude":
        selected.add("claude")
    return sorted(selected)


def main() -> int:
    args = parse_args()
    preset_explicit = "--preset" in sys.argv
    target_dir = Path(args.dir).expanduser().resolve()
    if not target_dir.is_dir():
        print(f"Error: target directory does not exist: {target_dir}", file=sys.stderr)
        return 1

    selected_targets = collect_selected_targets(args)
    blueprint_path, created = bootstrap_blueprint(target_dir, args.preset)

    if created:
        print(f"Created {blueprint_path} using preset '{args.preset}'.")
        if selected_targets:
            print("Edit init-orch.md to describe your orchestration design, then rerun init-orch.")
            return 0
    elif preset_explicit:
        print(f"Preset '{args.preset}' ignored because init-orch.md already exists.")

    if not selected_targets:
        if args.init or created:
            print("init-orch.md is ready. Fill it in, then rerun with --cursor, --claude, or --all.")
            return 0
        print("Nothing to render. Use --cursor, --claude, or --all after editing init-orch.md.")
        return 0

    try:
        render_targets(target_dir, selected_targets, blueprint_path)
    except ValueError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    print("Rendered orchestration files for " + ", ".join(selected_targets) + f" in {target_dir}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
