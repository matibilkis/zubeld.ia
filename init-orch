#!/usr/bin/env python3
"""Minimal Claude Code setup wizard."""

from __future__ import annotations

import json
import sys
from pathlib import Path


def write_text(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")


def ensure_line_in_file(path: Path, line: str) -> None:
    if path.exists():
        existing = path.read_text(encoding="utf-8")
        if line in existing.splitlines():
            return
        content = existing if existing.endswith("\n") else existing + "\n"
        path.write_text(content + line + "\n", encoding="utf-8")
    else:
        path.write_text(line + "\n", encoding="utf-8")


def prompt(label: str, default: str = "") -> str:
    if not sys.stdin.isatty():
        line = sys.stdin.readline()
        return line.rstrip("\n") if line else default
    hint = f" [{default}]" if default else ""
    try:
        value = input(f"{label}{hint}: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return default
    return value if value else default


def build_commands_block(run: str, test: str) -> str:
    lines = []
    if run:
        lines.append(f"- Run: `{run}`")
    if test:
        lines.append(f"- Test: `{test}`")
    return "\n".join(lines) if lines else "- (add run/test commands here)"


def render_claude_md(name: str, desc: str, run: str, test: str) -> str:
    commands = build_commands_block(run, test)
    desc_block = f"\n{desc}\n" if desc.strip() else ""
    return f"""\
# {name}
{desc_block}
## Commands

{commands}

## Rules

- Confirm before destructive or irreversible actions.
- Leave secrets and credentials untouched.
- Prefer small, focused changes over large rewrites.
- Lead with the answer. Keep responses short unless asked for more.

<examples>
- Do: "Fixed expiry check on line 42. Tests pass."
- Avoid: "Sure! I'd be happy to help. The issue may be caused by..."
</examples>
"""


def render_settings_json() -> str:
    return json.dumps(
        {
            "permissions": {
                "allow": ["Read(*)", "Glob(*)", "Grep(*)", "WebFetch", "WebSearch"],
                "deny": ["Bash(rm *)", "Bash(sudo *)", "Edit(.env*)"],
            }
        },
        indent=2,
    )


def main() -> int:
    target_dir = Path.cwd()
    claude_md = target_dir / "CLAUDE.md"

    if claude_md.exists():
        print(f"CLAUDE.md already exists in {target_dir}.")
        try:
            answer = input("Overwrite? [y/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            answer = ""
        if answer != "y":
            print("Cancelled.")
            return 0

    print()
    desc = prompt("What does this project do? (one line, include stack)")
    run  = prompt("Run command  (blank to skip)")
    test = prompt("Test command (blank to skip)")
    print()

    name = target_dir.name or "project"

    write_text(claude_md, render_claude_md(name, desc, run, test))
    write_text(target_dir / ".claude" / "settings.json", render_settings_json())
    ensure_line_in_file(target_dir / ".gitignore", ".claude/settings.local.json")

    print("Done.")
    print()
    print("Next:")
    print("  1. Edit CLAUDE.md — add mission and any project-specific rules.")
    print("  2. Create .claude/settings.local.json (gitignored) for local broader permissions:")
    print('     {"permissions": {"allow": ["Bash(*)", "Edit(*)", "Write(*)", "Read(*)", "Glob(*)", "Grep(*)", "WebFetch(*)", "WebSearch(*)"], "defaultMode": "acceptEdits"}}')
    return 0


if __name__ == "__main__":
    sys.exit(main())
