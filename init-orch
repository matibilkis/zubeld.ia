            "structure": "answer-first",
            "defaultLength": "very-short",
            "rules": [
                "Lead with the result, next experiment, or blocker immediately.",
                "Favor concise updates over polished exposition.",
                "Call out shortcuts, risks, and what would need hardening before production use.",
            ],
            "examples": [
                "Do: `Prototype works for the happy path. Next: test two failure cases and note the shortcuts we took.`",
                "Avoid: `Here is a long polished explanation of the prototype before we know if the idea works.`",
            ],
        },
        "docs": {
            "tone": "editorial",
            "verbosity": "balanced",
            "structure": "reader-first",
            "defaultLength": "short",
            "rules": [
                "Lead with the clearest wording or structure recommendation for the reader.",
                "Prefer concrete wording, examples, and scannable structure over abstract commentary.",
                "Call out ambiguity, broken references, and user-facing terminology changes explicitly.",
            ],
            "examples": [
                "Do: `Recommended rewrite: rename this section to 'Install locally' and move the prerequisite list above the command block.`",
                "Avoid: `The docs seem mostly okay, though maybe some wording could be improved somewhere.`",
            ],
        },
        "ops": {
            "tone": "cautious",
            "verbosity": "balanced",
            "structure": "risk-first",
