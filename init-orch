    ensure_line_in_file(target_dir / ".gitignore", ".claude/settings.local.json")
    return generated


def render_targets(
    target_dir: Path,
    selected_targets: list[str],
    blueprint_path: Path,
    confirm_existing: bool = False,
) -> None:
    blueprint_text = read_text(blueprint_path)
    try:
        raw_spec = json.loads(extract_block(blueprint_text, SPEC_MARKERS, "spec"))
    except json.JSONDecodeError as exc:
        raise ValueError(f"Invalid JSON in the spec block: {exc}") from exc

    spec = normalize_spec(raw_spec)
    metadata = load_generated_metadata(blueprint_text)
    ownership = build_render_ownership(target_dir, spec, selected_targets)
    conflicts = collect_render_conflicts(target_dir, ownership, metadata)
    if conflict_report_has_items(conflicts) and not confirm_existing:
        summary = format_collision_summary(conflicts)
        if sys.stdin.isatty() and sys.stdout.isatty():
            print(summary)
            if not prompt_yes_no("Continue with the render anyway?", default=False):
                raise ValueError("Render cancelled because generated paths overlap existing repo structure.")
        else:
            raise ValueError(summary + "\nRe-run with --confirm-existing after reviewing those paths.")

    recommendations = generate_recommendations(spec)
    generated_paths = render_shared_files(target_dir, spec, recommendations)

    if "cursor" in selected_targets:
        generated_paths.extend(render_cursor_files(target_dir, spec, recommendations))
    if "claude" in selected_targets:
        generated_paths.extend(render_claude_files(target_dir, spec, recommendations))

    metadata = {
        "version": 2,
        "lastRenderedAt": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "renderedTargets": selected_targets,
        "generatedFiles": sorted(str(path.relative_to(target_dir)) for path in generated_paths),
        "specDigest": spec_digest(spec),
        "bootstrapPreset": spec["preset"],
        "workflowPreset": spec["workflowPreset"],
        "domainPreset": spec["domainPreset"],
        "resolvedImports": [
            {
                "id": item["id"],
                "type": item["type"],
                "targets": item["targets"],
                "version": item["version"],
            }
            for item in spec["imports"]
        ],
    }
    updated_blueprint = replace_block(blueprint_text, GENERATED_MARKERS, metadata)
    updated_blueprint = replace_block(updated_blueprint, RECOMMENDATION_MARKERS, recommendations)
    write_text(blueprint_path, updated_blueprint)


def collect_selected_targets(args: argparse.Namespace) -> list[str]:
    selected = set()
    if args.all or args.legacy_mode == "all":
        selected.update(VALID_TARGETS)
    if args.cursor or args.legacy_mode == "cursor":
        selected.add("cursor")
    if args.claude or args.legacy_mode == "claude":
        selected.add("claude")
    return sorted(selected)


def should_run_guided_bootstrap(
    args: argparse.Namespace,
    target_dir: Path,
    selected_targets: list[str],
    preset_explicit: bool,
) -> bool:
    blueprint_path = target_dir / "init-orch.md"
    if blueprint_path.exists() or args.no_interactive or args.review or args.refine:
        return False
    if args.interactive:
        return True
    return (
        not preset_explicit
        and not selected_targets
        and sys.stdin.isatty()
        and sys.stdout.isatty()
    )


def main() -> int:
    args = parse_args()
    preset_explicit = "--preset" in sys.argv
    target_dir = Path(args.dir).expanduser().resolve()
    if not target_dir.is_dir():
        print(f"Error: target directory does not exist: {target_dir}", file=sys.stderr)
        return 1

    selected_targets = collect_selected_targets(args)
    if args.confirm_existing and (args.review or args.refine or not selected_targets):
        print("Error: --confirm-existing only applies to render commands.", file=sys.stderr)
        return 1
    if args.review and (args.init or selected_targets or args.refine):
        print("Error: --review cannot be combined with --init, --cursor, --claude, --all, or --refine.", file=sys.stderr)
        return 1
    if args.refine and (args.init or selected_targets):
        print("Error: --refine cannot be combined with --init, --cursor, --claude, or --all.", file=sys.stderr)
        return 1

    blueprint_path = target_dir / "init-orch.md"
    if args.review:
        if not blueprint_path.exists():
            print("Error: init-orch.md does not exist yet. Run init-orch first.", file=sys.stderr)
            return 1
        try:
            print(review_blueprint(target_dir, blueprint_path))
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1
        return 0

    if args.refine:
        if not blueprint_path.exists():
            print("Error: init-orch.md does not exist yet. Run init-orch first.", file=sys.stderr)
            return 1
        try:
            run_refine_step(target_dir, blueprint_path)
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1
        return 0

    bootstrap_preset = args.preset
    guided_bootstrap_used = False
    guided_targets: list[str] = []
    if should_run_guided_bootstrap(args, target_dir, selected_targets, preset_explicit):
        blueprint_path, created, bootstrap_preset, guided_targets = run_guided_bootstrap(target_dir, args.preset)
        if not created:
            return 0
        guided_bootstrap_used = True
    else:
        blueprint_path, created = bootstrap_blueprint(target_dir, args.preset)

    if created:
        print(f"Created {blueprint_path} using preset '{bootstrap_preset}'.")
        if guided_bootstrap_used:
            effective_targets = guided_targets or selected_targets
            next_render = (
                f"init-orch --{effective_targets[0]}"
                if len(effective_targets) == 1
                else "init-orch --all"
            )
            print("Start with mission, success criteria, verification, and roles in init-orch.md.")
            print(f"Then run {next_render} to compile the first target files.")
            print("After the first render, run init-orch --refine to tailor the setup to the repo.")
            print("Later, run init-orch --review when you want practical setup feedback.")
        if selected_targets:
            print("Refine init-orch.md, then rerun init-orch to compile the target files.")
            return 0
    elif preset_explicit:
        print(f"Preset '{args.preset}' ignored because init-orch.md already exists.")

    if not selected_targets:
        if guided_bootstrap_used:
            return 0
        if args.init or created:
            print("init-orch.md is ready. Fill it in, then rerun with --cursor, --claude, or --all.")
            return 0
        print("Nothing to render yet. Edit init-orch.md, then use --cursor, --claude, or --all.")
        return 0

    try:
        render_targets(target_dir, selected_targets, blueprint_path, confirm_existing=args.confirm_existing)
    except ValueError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    print("Rendered orchestration files for " + ", ".join(selected_targets) + f" in {target_dir}")
    print("Next: run init-orch --refine to tailor the setup to this repo.")
    print("Then use init-orch --review for periodic repo-specific recommendations.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
