        },
        "research": {
            "tone": "analytical",
            "verbosity": "detailed",
            "structure": "findings-first",
            "defaultLength": "medium",
            "rules": [
                "Lead with the main finding or recommendation, then show the supporting evidence.",
                "Separate findings, hypotheses, assumptions, and open questions explicitly.",
                "State confidence level and notable caveats when the evidence is incomplete.",
            ],
            "examples": [
                "Do: `Main finding: the current onboarding drop-off is at the permissions step. Evidence: logs from the last 14 days and three support tickets. Confidence: medium.`",
                "Avoid: `I think the issue might maybe be onboarding, but I'd need to look around more.`",
