def json_block(markers: tuple[str, str], data: object) -> str:
    start, end = markers
    payload = json.dumps(data, indent=2)
    return f"{start}\n```json\n{payload}\n```\n{end}"


def spec_digest(spec: object) -> str:
    payload = json.dumps(spec, sort_keys=True, separators=(",", ":"))
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def write_text(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content.rstrip() + "\n", encoding="utf-8")


def ensure_line_in_file(path: Path, line: str) -> None:
    if path.exists():
        lines = path.read_text(encoding="utf-8").splitlines()
    else:
        path.parent.mkdir(parents=True, exist_ok=True)
        lines = []

    if line not in lines:
        lines.append(line)
        path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")


def updated_line_content(path: Path, line: str) -> str:
    if path.exists():
        lines = path.read_text(encoding="utf-8").splitlines()
    else:
        lines = []
    if line not in lines:
        lines.append(line)
    return "\n".join(lines).rstrip() + "\n"


def extract_block(text: str, markers: tuple[str, str], label: str) -> str:
    start, end = markers
    pattern = re.compile(
        re.escape(start) + r"\s*```json\s*(.*?)\s*```\s*" + re.escape(end),
        re.DOTALL,
    )
    match = pattern.search(text)
    if not match:
        raise ValueError(f"Could not find the {label} JSON block in init-orch.md.")
    return match.group(1)


def replace_block(text: str, markers: tuple[str, str], payload: object) -> str:
    start, end = markers
    replacement = f"{start}\n```json\n{json.dumps(payload, indent=2)}\n```\n{end}"
    pattern = re.compile(
        re.escape(start) + r"\s*```json\s*.*?\s*```\s*" + re.escape(end),
        re.DOTALL,
    )
    if pattern.search(text):
        return pattern.sub(replacement, text, count=1)
    if not text.endswith("\n"):
        text += "\n"
    return text + "\n" + replacement + "\n"


def sanitize_filename(value: str, fallback: str) -> str:
    sanitized = re.sub(r"[^A-Za-z0-9._-]+", "-", value.strip()).strip("-")
    return sanitized or fallback


def require_dict(value: object, field_name: str) -> dict:
    if not isinstance(value, dict):
        raise ValueError(f"`{field_name}` must be a JSON object.")
    return value


def require_string_list(value: object, field_name: str) -> list[str]:
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        raise ValueError(f"`{field_name}` must be a JSON array of strings.")
    return value


def normalize_string(value: object, fallback: str) -> str:
    if isinstance(value, str) and value.strip():
        return value.strip()
    return fallback


def compose_preset(workflow: str, domain: str) -> str:
    return f"{workflow}-{domain}"


def split_preset_name(preset: str) -> tuple[str, str]:
    workflow, separator, domain = preset.partition("-")
    if not separator or not workflow or not domain:
        raise ValueError(
            "Preset must use `workflow-domain` form, for example `engineering-web-app`."
        )
    return workflow, domain


def validate_preset_parts(workflow: str, domain: str) -> tuple[str, str]:
    if workflow not in VALID_WORKFLOW_PRESETS:
        raise ValueError(
            "`workflowPreset` must be one of: " + ", ".join(sorted(VALID_WORKFLOW_PRESETS))
        )
    if domain not in VALID_DOMAIN_PRESETS:
        raise ValueError(
            "`domainPreset` must be one of: " + ", ".join(sorted(VALID_DOMAIN_PRESETS))
        )
    return workflow, domain


def normalize_composed_preset(preset: str) -> tuple[str, str, str]:
    workflow, domain = split_preset_name(normalize_string(preset, DEFAULT_PRESET))
    workflow, domain = validate_preset_parts(workflow, domain)
    return compose_preset(workflow, domain), workflow, domain


def parse_preset_arg(value: str) -> str:
    try:
        preset, _, _ = normalize_composed_preset(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(str(exc)) from exc
    return preset


def resolve_preset_fields(spec: dict) -> tuple[str, str, str]:
    workflow = normalize_string(spec.get("workflowPreset"), "")
    domain = normalize_string(spec.get("domainPreset"), "")
    preset = normalize_string(spec.get("preset"), "")

    if workflow or domain:
        if not workflow or not domain:
            raise ValueError("`workflowPreset` and `domainPreset` must either both be set or both be omitted.")
        workflow, domain = validate_preset_parts(workflow, domain)
        return compose_preset(workflow, domain), workflow, domain

    if preset:
        return normalize_composed_preset(preset)

    return DEFAULT_PRESET, DEFAULT_WORKFLOW_PRESET, DEFAULT_DOMAIN_PRESET


