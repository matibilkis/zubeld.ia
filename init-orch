def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Bootstrap, compile, and review orchestration files from init-orch.md.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent(
            """\
            Examples:
              init-orch
              init-orch --preset research-docs
              init-orch --init
              init-orch --preset engineering-web-app --init
              init-orch --cursor
              init-orch --claude
              init-orch --all
              init-orch --review
              init-orch --refine
              init-orch --suggest
              init-orch --all --confirm-existing
              init-orch --dir /path/to/repo --all

            Notes:
              - On first run in a terminal, init-orch can guide you through a short bootstrap flow.
              - init-orch.md is the only high-level file you edit directly.
              - Rendering compiles that spec into tool-specific files and stops for confirmation if it detects existing owned-looking structure.
              - Suggest mode proposes better summary, mission, success criteria, and verification from a small amount of repo evidence.
              - Refinement collects repo-specific details after the first render.
              - Review mode prints practical recommendations without rewriting your setup.
            """
        ),
    )
    parser.add_argument("--dir", default=".", help="Target repository root. Defaults to cwd.")
    parser.add_argument(
        "--preset",
        type=parse_preset_arg,
        default=DEFAULT_PRESET,
        help=(
            "Bootstrap preset for the first init-orch.md in workflow-domain form. "
            f"Workflows: {', '.join(VALID_WORKFLOW_PRESETS)}. "
            f"Domains: {', '.join(VALID_DOMAIN_PRESETS)}. "
            f"Default: {DEFAULT_PRESET}."
        ),
    )
    parser.add_argument(
        "--init",
        action="store_true",
        help="Bootstrap init-orch.md if missing, without rendering tool-specific files.",
    )
    parser.add_argument("--cursor", action="store_true", help="Render Cursor scaffolding.")
    parser.add_argument("--claude", action="store_true", help="Render Claude scaffolding.")
    parser.add_argument("--all", action="store_true", help="Render both Cursor and Claude.")
    parser.add_argument(
        "--confirm-existing",
        action="store_true",
        help="Proceed when init-orch detects existing owned-looking structure during render.",
    )
    parser.add_argument(
        "--review",
        action="store_true",
        help="Print practical setup recommendations without rewriting files.",
    )
    parser.add_argument(
        "--suggest",
        action="store_true",
        help="Propose repo-aware updates for summary, mission, success criteria, and verification.",
    )
    parser.add_argument(
        "--refine",
        action="store_true",
        help="Collect repo-specific details and fold them back into init-orch.md.",
    )
    interactive_group = parser.add_mutually_exclusive_group()
    interactive_group.add_argument(
        "--interactive",
        action="store_true",
        help="Force the guided bootstrap flow when creating init-orch.md.",
