def build_cursor_mcp_manifest(spec: dict) -> dict:
    servers = {}
    for server in spec["mcpServers"]:
        if "cursor" not in server["targets"]:
            continue
        transport = server["transport"]
        if transport["type"] == "stdio":
            servers[server["id"]] = {
                "command": transport["command"],
                "args": transport["args"],
                "env": transport["env"],
            }
        elif transport["type"] == "http":
            servers[server["id"]] = {
                "url": transport["url"],
            }
    return {"mcpServers": servers}


def render_shared_files(target_dir: Path, spec: dict, recommendations: dict) -> list[Path]:
    generated = []
    agents_path = target_dir / "AGENTS.md"
    policy_path = target_dir / "orch" / "permissions.policy.json"
    imports_path = target_dir / "orch" / "imports.lock.json"
    evaluation_path = target_dir / "orch" / "evaluation.plan.json"
    write_text(agents_path, render_agents_file(spec, recommendations))
    write_text(policy_path, render_policy_file(spec))
    write_text(imports_path, render_import_lock(spec))
    write_text(evaluation_path, render_evaluation_plan(spec, recommendations))
    generated.extend([agents_path, policy_path, imports_path, evaluation_path])
    return generated


def render_cursor_files(target_dir: Path, spec: dict, recommendations: dict) -> list[Path]:
    generated = []
    rules_dir = target_dir / ".cursor" / "rules"
    skills_dir = target_dir / ".cursor" / "skills"
    imports_dir = target_dir / ".cursor" / "imports"
    rules_dir.mkdir(parents=True, exist_ok=True)
    skills_dir.mkdir(parents=True, exist_ok=True)
    imports_dir.mkdir(parents=True, exist_ok=True)

    rule_paths = {
        "core": rules_dir / "core.mdc",
        "policy": rules_dir / "orchestrator-policy.mdc",
        "workflow": rules_dir / "workflow.mdc",
        "evaluation": rules_dir / "evaluation.mdc",
    }
    write_text(rule_paths["core"], render_cursor_core_rule(spec))
    write_text(rule_paths["policy"], render_cursor_policy_rule(spec))
    write_text(rule_paths["workflow"], render_cursor_workflow_rule(spec))
    write_text(rule_paths["evaluation"], render_cursor_evaluation_rule(spec, recommendations))
    generated.extend(rule_paths.values())

    manifest_path = imports_dir / "manifest.json"
    write_text(
        manifest_path,
        json.dumps(
            {
                "imports": [item for item in spec["imports"] if "cursor" in item["targets"]],
                "securityWarning": SECURITY_WARNING,
            },
            indent=2,
        ),
    )
    generated.append(manifest_path)

    cursor_mcp_servers = build_cursor_mcp_manifest(spec)
    if cursor_mcp_servers["mcpServers"]:
        mcp_path = target_dir / ".cursor" / "mcp.json"
        write_text(mcp_path, json.dumps(cursor_mcp_servers, indent=2))
        generated.append(mcp_path)

    if spec["skills"]:
        for skill in spec["skills"]:
            skill_dir = skills_dir / sanitize_filename(skill["id"], "skill")
            skill_path = skill_dir / "SKILL.md"
            write_text(skill_path, render_cursor_skill(skill))
            generated.append(skill_path)
    else:
        gitkeep = skills_dir / ".gitkeep"
        gitkeep.touch(exist_ok=True)
        generated.append(gitkeep)
    return generated


