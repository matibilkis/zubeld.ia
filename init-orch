def add_verification_requirement(raw_spec: dict, change_types: list[str], requirement: str) -> None:
    verification = raw_spec.setdefault("verification", [])
    if not isinstance(verification, list):
        raw_spec["verification"] = []
        verification = raw_spec["verification"]
    for change_type in change_types:
        for entry in verification:
            if isinstance(entry, dict) and normalize_string(entry.get("changeType"), "") == change_type:
                required = entry.setdefault("required", [])
                if isinstance(required, list) and requirement not in required:
                    required.append(requirement)
                return
    verification.append({"changeType": change_types[0], "required": [requirement]})


